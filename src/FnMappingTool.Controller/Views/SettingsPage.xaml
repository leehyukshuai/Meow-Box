<Page
    x:Class="FnMappingTool.Controller.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer>
        <Grid Padding="{StaticResource AppPagePadding}" RowSpacing="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" MinWidth="420" />
                    <ColumnDefinition Width="*" MinWidth="280" />
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource HeroPanelCardStyle}">
                    <StackPanel Spacing="10">
                        <TextBlock Style="{StaticResource SectionEyebrowTextBlockStyle}" Text="Runtime preferences" />
                        <TextBlock Style="{StaticResource PageTitleTextBlockStyle}" Text="Keep the tool quiet, reliable, and easy to trust" />
                        <TextBlock
                            Style="{StaticResource PageSubtitleTextBlockStyle}"
                            Text="Service state, startup behavior, tray visibility, and presets all live here so the rest of the app can stay focused on editing."
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </Border>

                <StackPanel Grid.Column="1" Spacing="16">
                    <Border Style="{StaticResource StatCardStyle}">
                        <StackPanel Spacing="6">
                            <TextBlock Style="{StaticResource CaptionTextBlockStyle}" Text="Service status" />
                            <TextBlock Style="{StaticResource CardTitleTextBlockStyle}" Text="{Binding ServiceStatusLabel}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource StatCardStyle}">
                        <StackPanel Spacing="6">
                            <TextBlock Style="{StaticResource CaptionTextBlockStyle}" Text="Configuration" />
                            <TextBlock Style="{StaticResource CardBodyTextBlockStyle}" Text="The UI edits config only. The worker applies changes immediately when it is running." TextWrapping="WrapWholeWords" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1" ColumnSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource PanelCardStyle}">
                    <StackPanel Spacing="18">
                        <TextBlock Style="{StaticResource SectionTitleTextBlockStyle}" Text="Background service" />

                        <Border Style="{StaticResource SubtlePanelCardStyle}">
                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="4">
                                    <TextBlock Style="{StaticResource CardTitleTextBlockStyle}" Text="Service" />
                                    <TextBlock Style="{StaticResource CardBodyTextBlockStyle}" Text="Turn the worker on when you want OEM events to be captured and mappings to execute." TextWrapping="WrapWholeWords" />
                                </StackPanel>
                                <ToggleSwitch
                                    x:Name="ServiceToggleSwitch"
                                    Grid.Column="1"
                                    Header="Running"
                                    Toggled="OnServiceStateChanged" />
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource SubtlePanelCardStyle}">
                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="4">
                                    <TextBlock Style="{StaticResource CardTitleTextBlockStyle}" Text="Start with Windows" />
                                    <TextBlock Style="{StaticResource CardBodyTextBlockStyle}" Text="Recommended if you want laptop keys to keep working without opening the controller first." TextWrapping="WrapWholeWords" />
                                </StackPanel>
                                <ToggleSwitch
                                    x:Name="AutostartToggleSwitch"
                                    Grid.Column="1"
                                    Header="Enabled"
                                    Toggled="OnAutostartChanged" />
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource SubtlePanelCardStyle}">
                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="4">
                                    <TextBlock Style="{StaticResource CardTitleTextBlockStyle}" Text="Tray icon" />
                                    <TextBlock Style="{StaticResource CardBodyTextBlockStyle}" Text="Keep a lightweight system tray presence for quick open and exit controls." TextWrapping="WrapWholeWords" />
                                </StackPanel>
                                <ToggleSwitch
                                    x:Name="TrayIconToggleSwitch"
                                    Grid.Column="1"
                                    Header="Shown"
                                    Toggled="OnTrayIconChanged" />
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource PanelCardStyle}">
                    <StackPanel Spacing="18">
                        <TextBlock Style="{StaticResource SectionTitleTextBlockStyle}" Text="Appearance and files" />

                        <ComboBox
                            x:Name="ThemeComboBox"
                            Header="Theme"
                            SelectionChanged="OnThemeSelectionChanged">
                            <ComboBoxItem Content="System" Tag="System" />
                            <ComboBoxItem Content="Light" Tag="Light" />
                            <ComboBoxItem Content="Dark" Tag="Dark" />
                        </ComboBox>

                        <TextBox
                            Header="Config file"
                            IsReadOnly="True"
                            Text="{Binding ConfigPath}" />

                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Button Click="OnOpenConfigFolderClick" Content="Open Config Folder" Style="{StaticResource SubtleButtonStyle}" />
                            <Button Click="OnImportConfigClick" Content="Import JSON File" Style="{StaticResource SubtleButtonStyle}" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="2" Style="{StaticResource PanelCardStyle}">
                <Grid ColumnSpacing="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="280" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Spacing="16">
                        <TextBlock Style="{StaticResource SectionTitleTextBlockStyle}" Text="Presets" />
                        <TextBlock
                            Style="{StaticResource CardBodyTextBlockStyle}"
                            Text="Load a prepared mapping profile when you want a fast starting point for a supported laptop model."
                            TextWrapping="WrapWholeWords" />

                        <ComboBox
                            x:Name="PresetComboBox"
                            DisplayMemberPath="Name"
                            Header="Built-in preset"
                            ItemsSource="{Binding PresetConfigurations}" />
                    </StackPanel>

                    <Border Grid.Column="1" Style="{StaticResource SubtlePanelCardStyle}">
                        <StackPanel Spacing="14">
                            <TextBlock Style="{StaticResource CardTitleTextBlockStyle}" Text="Apply preset" />
                            <TextBlock
                                Style="{StaticResource CardBodyTextBlockStyle}"
                                Text="This replaces the current configuration with the selected preset. Use it when you want a clean starting configuration."
                                TextWrapping="WrapWholeWords" />
                            <Button Click="OnLoadPresetClick" Content="Load Preset" HorizontalAlignment="Left" Style="{StaticResource AccentButtonStyle}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
