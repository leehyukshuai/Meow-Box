<Page
    x:Class="FnMappingTool.Controller.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer HorizontalScrollBarVisibility="Disabled">
        <Grid Padding="{StaticResource AppPagePadding}" RowSpacing="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Style="{StaticResource PageTitleTextBlockStyle}" Text="Settings" />

            <Grid
                x:Name="SettingsSectionsGrid"
                Grid.Row="1"
                RowSpacing="16">
                <VisualStateManager.VisualStateGroups>
                    <VisualStateGroup>
                        <VisualState x:Name="WideLayout">
                            <VisualState.StateTriggers>
                                <AdaptiveTrigger MinWindowWidth="1040" />
                            </VisualState.StateTriggers>
                            <VisualState.Setters>
                                <Setter Target="SettingsSectionsGrid.ColumnSpacing" Value="16" />
                                <Setter Target="SettingsLeftColumn.Width" Value="*" />
                                <Setter Target="SettingsRightColumn.Width" Value="*" />
                                <Setter Target="ServiceCard.(Grid.Row)" Value="0" />
                                <Setter Target="ServiceCard.(Grid.Column)" Value="0" />
                                <Setter Target="AppearanceCard.(Grid.Row)" Value="0" />
                                <Setter Target="AppearanceCard.(Grid.Column)" Value="1" />
                                <Setter Target="ConfigsCard.(Grid.Row)" Value="1" />
                                <Setter Target="ConfigsCard.(Grid.Column)" Value="0" />
                                <Setter Target="FilesCard.(Grid.Row)" Value="1" />
                                <Setter Target="FilesCard.(Grid.Column)" Value="1" />
                            </VisualState.Setters>
                        </VisualState>
                    </VisualStateGroup>
                </VisualStateManager.VisualStateGroups>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="SettingsLeftColumn" Width="*" />
                    <ColumnDefinition x:Name="SettingsRightColumn" Width="0" />
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border
                    x:Name="ServiceCard"
                    Grid.Row="0"
                    Grid.Column="0"
                    Style="{StaticResource PanelCardStyle}">
                    <Grid RowSpacing="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Style="{StaticResource SectionTitleTextBlockStyle}" Text="Service" />

                        <Grid Grid.Row="1" ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock VerticalAlignment="Center" Style="{StaticResource CardTitleTextBlockStyle}" Text="Running" />
                            <ToggleSwitch
                                x:Name="ServiceToggleSwitch"
                                Grid.Column="1"
                                Toggled="OnServiceStateChanged" />
                        </Grid>

                        <Grid Grid.Row="2" ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock VerticalAlignment="Center" Style="{StaticResource CardTitleTextBlockStyle}" Text="Start with Windows" />
                            <ToggleSwitch
                                x:Name="AutostartToggleSwitch"
                                Grid.Column="1"
                                Toggled="OnAutostartChanged" />
                        </Grid>

                        <Grid Grid.Row="3" ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock VerticalAlignment="Center" Style="{StaticResource CardTitleTextBlockStyle}" Text="Tray icon" />
                            <ToggleSwitch
                                x:Name="TrayIconToggleSwitch"
                                Grid.Column="1"
                                Toggled="OnTrayIconChanged" />
                        </Grid>
                    </Grid>
                </Border>

                <Border
                    x:Name="AppearanceCard"
                    Grid.Row="1"
                    Grid.Column="0"
                    Style="{StaticResource PanelCardStyle}">
                    <StackPanel Spacing="16">
                        <TextBlock Style="{StaticResource SectionTitleTextBlockStyle}" Text="Appearance" />

                        <ComboBox
                            x:Name="ThemeComboBox"
                            Header="Theme"
                            SelectionChanged="OnThemeSelectionChanged">
                            <ComboBoxItem Content="System" Tag="System" />
                            <ComboBoxItem Content="Light" Tag="Light" />
                            <ComboBoxItem Content="Dark" Tag="Dark" />
                        </ComboBox>
                    </StackPanel>
                </Border>

                <Border
                    x:Name="ConfigsCard"
                    Grid.Row="2"
                    Grid.Column="0"
                    Style="{StaticResource PanelCardStyle}">
                    <Grid RowSpacing="14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Style="{StaticResource SectionTitleTextBlockStyle}" Text="Configs" />

                        <Grid Grid.Row="1" ColumnSpacing="16" RowSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <ComboBox
                                x:Name="OsdDisplayModeComboBox"
                                Header="OSD content"
                                SelectionChanged="OnOsdSettingChanged">
                                <ComboBoxItem Content="Icon + title" Tag="IconAndText" />
                                <ComboBoxItem Content="Icon only" Tag="IconOnly" />
                                <ComboBoxItem Content="Title only" Tag="TextOnly" />
                            </ComboBox>

                            <NumberBox
                                x:Name="OsdDurationNumberBox"
                                Grid.Column="1"
                                Header="OSD duration (ms)"
                                Minimum="500"
                                Maximum="10000"
                                SmallChange="100"
                                SpinButtonPlacementMode="Inline"
                                ValueChanged="OnOsdNumberValueChanged" />

                            <NumberBox
                                x:Name="OsdBackgroundOpacityNumberBox"
                                Grid.Row="1"
                                Header="Background opacity (%)"
                                Minimum="0"
                                Maximum="100"
                                SmallChange="5"
                                SpinButtonPlacementMode="Inline"
                                ValueChanged="OnOsdNumberValueChanged" />

                            <NumberBox
                                x:Name="OsdScaleNumberBox"
                                Grid.Row="1"
                                Grid.Column="1"
                                Header="OSD size (%)"
                                Minimum="60"
                                Maximum="200"
                                SmallChange="10"
                                SpinButtonPlacementMode="Inline"
                                ValueChanged="OnOsdNumberValueChanged" />

                            <TextBox
                                x:Name="OsdIconFolderTextBox"
                                Grid.Row="2"
                                Grid.ColumnSpan="2"
                                Header="OSD icon folder"
                                IsReadOnly="True" />

                            <StackPanel
                                Grid.Row="3"
                                Grid.ColumnSpan="2"
                                Spacing="10">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <Button Click="OnOpenOsdIconFolderClick" Content="Open icon folder" Style="{StaticResource SubtleButtonStyle}" />
                                    <Button Click="OnRefreshOsdIconFolderClick" Content="Refresh icons" Style="{StaticResource SubtleButtonStyle}" />
                                </StackPanel>

                                <TextBlock
                                    Style="{StaticResource CardBodyTextBlockStyle}"
                                    Text="Icon spec: transparent PNG, square canvas, 256×256 recommended, single-color glyph, and leave some padding near the edge."
                                    TextWrapping="WrapWholeWords" />
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <Border
                    x:Name="FilesCard"
                    Grid.Row="3"
                    Grid.Column="0"
                    Style="{StaticResource PanelCardStyle}">
                    <Grid RowSpacing="14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Style="{StaticResource SectionTitleTextBlockStyle}" Text="Files" />

                        <StackPanel Grid.Row="1" Spacing="12">
                            <TextBlock
                                Style="{StaticResource CardBodyTextBlockStyle}"
                                Text="Preset files live in their own folder. Copy JSON presets there, refresh the list, then load one."
                                TextWrapping="WrapWholeWords" />

                            <TextBox
                                x:Name="PresetDirectoryTextBox"
                                Header="Preset folder"
                                IsReadOnly="True"
                                Text="{Binding PresetDirectory}" />
                        </StackPanel>

                        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="12">
                            <Button Click="OnOpenPresetFolderClick" Content="Open preset folder" Style="{StaticResource AccentButtonStyle}" />
                            <Button Click="OnRefreshConfigFilesClick" Content="Refresh list" Style="{StaticResource SubtleButtonStyle}" />
                        </StackPanel>

                        <Grid Grid.Row="3" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <ComboBox
                                x:Name="ConfigFilesComboBox"
                                DisplayMemberPath="DisplayName"
                                Header="Preset files"
                                PlaceholderText="No preset JSON files found"
                                SelectionChanged="OnConfigFileSelectionChanged"
                                SelectedValuePath="Path" />

                            <Button
                                x:Name="LoadPresetButton"
                                Grid.Column="1"
                                Click="OnImportSelectedConfigClick"
                                Content="Load preset"
                                Style="{StaticResource AccentButtonStyle}" />
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</Page>
