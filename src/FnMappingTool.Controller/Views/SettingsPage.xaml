<Page
    x:Class="FnMappingTool.Controller.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer HorizontalScrollBarVisibility="Disabled">
        <Grid Padding="{StaticResource AppPagePadding}" RowSpacing="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock x:Uid="SettingsPageTitleText" Style="{StaticResource PageTitleTextBlockStyle}" Text="Settings" />

            <Grid x:Name="SettingsSectionsGrid" Grid.Row="1" RowSpacing="16">
                <VisualStateManager.VisualStateGroups>
                    <VisualStateGroup>
                        <VisualState x:Name="WideLayout">
                            <VisualState.StateTriggers>
                                <AdaptiveTrigger MinWindowWidth="1040" />
                            </VisualState.StateTriggers>
                            <VisualState.Setters>
                                <Setter Target="SettingsSectionsGrid.ColumnSpacing" Value="16" />
                                <Setter Target="SettingsLeftColumn.Width" Value="*" />
                                <Setter Target="SettingsRightColumn.Width" Value="*" />
                                <Setter Target="ServiceCard.(Grid.Row)" Value="0" />
                                <Setter Target="ServiceCard.(Grid.Column)" Value="0" />
                                <Setter Target="AppearanceCard.(Grid.Row)" Value="0" />
                                <Setter Target="AppearanceCard.(Grid.Column)" Value="1" />
                                <Setter Target="ConfigsCard.(Grid.Row)" Value="1" />
                                <Setter Target="ConfigsCard.(Grid.Column)" Value="0" />
                                <Setter Target="DeviceCard.(Grid.Row)" Value="1" />
                                <Setter Target="DeviceCard.(Grid.Column)" Value="1" />
                            </VisualState.Setters>
                        </VisualState>
                    </VisualStateGroup>
                </VisualStateManager.VisualStateGroups>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="SettingsLeftColumn" Width="*" />
                    <ColumnDefinition x:Name="SettingsRightColumn" Width="0" />
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border x:Name="ServiceCard" Grid.Row="0" Grid.Column="0" Style="{StaticResource PanelCardStyle}">
                    <Grid RowSpacing="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock x:Uid="ServiceCardTitleText" Style="{StaticResource SectionTitleTextBlockStyle}" Text="Service" />

                        <Grid Grid.Row="1" ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Uid="ServiceRunningText" VerticalAlignment="Center" Style="{StaticResource CardTitleTextBlockStyle}" Text="Running" />
                            <ToggleSwitch x:Name="ServiceToggleSwitch" Grid.Column="1" Toggled="OnServiceStateChanged" />
                        </Grid>

                        <Grid Grid.Row="2" ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Uid="AutostartText" VerticalAlignment="Center" Style="{StaticResource CardTitleTextBlockStyle}" Text="Start with Windows" />
                            <ToggleSwitch x:Name="AutostartToggleSwitch" Grid.Column="1" Toggled="OnAutostartChanged" />
                        </Grid>

                        <Grid Grid.Row="3" ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="4">
                                <TextBlock x:Uid="PriorityStartupTitleText" Style="{StaticResource CardTitleTextBlockStyle}" Text="Priority startup" />
                                <TextBlock x:Uid="PriorityStartupDescriptionText" Style="{StaticResource CaptionTextBlockStyle}" Text="Uses a Windows scheduled task instead of the Startup folder so Worker starts earlier after sign-in." TextWrapping="WrapWholeWords" />
                                <StackPanel x:Name="PriorityStartupBusyPanel" Orientation="Horizontal" Spacing="8" Visibility="Collapsed">
                                    <ProgressRing x:Name="PriorityStartupProgressRing" Width="16" Height="16" IsActive="False" />
                                    <TextBlock x:Uid="PriorityStartupBusyText" VerticalAlignment="Center" Style="{StaticResource CaptionTextBlockStyle}" Text="Applying..." />
                                </StackPanel>
                            </StackPanel>
                            <ToggleSwitch x:Name="PriorityStartupToggleSwitch" Grid.Column="1" Toggled="OnPriorityStartupChanged" />
                        </Grid>

                        <Grid Grid.Row="4" ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Uid="TrayIconText" VerticalAlignment="Center" Style="{StaticResource CardTitleTextBlockStyle}" Text="Tray icon" />
                            <ToggleSwitch x:Name="TrayIconToggleSwitch" Grid.Column="1" Toggled="OnTrayIconChanged" />
                        </Grid>
                    </Grid>
                </Border>

                <Border x:Name="AppearanceCard" Grid.Row="1" Grid.Column="0" Style="{StaticResource PanelCardStyle}">
                    <StackPanel Spacing="16">
                        <TextBlock x:Uid="AppearanceCardTitleText" Style="{StaticResource SectionTitleTextBlockStyle}" Text="Appearance" />

                        <ComboBox x:Uid="ThemeComboBox" x:Name="ThemeComboBox" Header="Theme" SelectionChanged="OnThemeSelectionChanged">
                            <ComboBoxItem x:Uid="ThemeSystemItem" Content="System" Tag="System" />
                            <ComboBoxItem x:Uid="ThemeLightItem" Content="Light" Tag="Light" />
                            <ComboBoxItem x:Uid="ThemeDarkItem" Content="Dark" Tag="Dark" />
                        </ComboBox>

                        <StackPanel Spacing="4">
                            <ComboBox x:Uid="LanguageComboBox" x:Name="LanguageComboBox" Header="Language" SelectionChanged="OnLanguageSelectionChanged">
                                <ComboBoxItem x:Uid="LanguageSystemItem" Content="Use system language" Tag="System" />
                                <ComboBoxItem x:Uid="LanguageEnglishItem" Content="English" Tag="English" />
                                <ComboBoxItem x:Uid="LanguageChineseItem" Content="Chinese" Tag="Chinese" />
                            </ComboBox>
                            <TextBlock x:Uid="LanguageRestartHintText" Style="{StaticResource CaptionTextBlockStyle}" Text="Language changes apply after restarting the app." TextWrapping="WrapWholeWords" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border x:Name="ConfigsCard" Grid.Row="2" Grid.Column="0" Style="{StaticResource PanelCardStyle}">
                    <Grid RowSpacing="14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock x:Uid="ConfigsCardTitleText" Style="{StaticResource SectionTitleTextBlockStyle}" Text="Configs" />

                        <Grid Grid.Row="1" ColumnSpacing="16" RowSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <ComboBox x:Uid="OsdDisplayModeComboBox" x:Name="OsdDisplayModeComboBox" Header="OSD content" SelectionChanged="OnOsdSettingChanged">
                                <ComboBoxItem x:Uid="OsdDisplayIconAndTitleItem" Content="Icon + title" Tag="IconAndText" />
                                <ComboBoxItem x:Uid="OsdDisplayIconOnlyItem" Content="Icon only" Tag="IconOnly" />
                                <ComboBoxItem x:Uid="OsdDisplayTitleOnlyItem" Content="Title only" Tag="TextOnly" />
                            </ComboBox>

                            <NumberBox x:Uid="OsdDurationNumberBox" x:Name="OsdDurationNumberBox" Grid.Column="1" Header="OSD duration (ms)" Minimum="500" Maximum="10000" SmallChange="100" SpinButtonPlacementMode="Inline" ValueChanged="OnOsdNumberValueChanged" />
                            <NumberBox x:Uid="OsdBackgroundOpacityNumberBox" x:Name="OsdBackgroundOpacityNumberBox" Grid.Row="1" Header="Background opacity (%)" Minimum="0" Maximum="100" SmallChange="5" SpinButtonPlacementMode="Inline" ValueChanged="OnOsdNumberValueChanged" />
                            <NumberBox x:Uid="OsdScaleNumberBox" x:Name="OsdScaleNumberBox" Grid.Row="1" Grid.Column="1" Header="OSD size (%)" Minimum="60" Maximum="200" SmallChange="10" SpinButtonPlacementMode="Inline" ValueChanged="OnOsdNumberValueChanged" />
                            <TextBox x:Uid="OsdIconFolderTextBox" x:Name="OsdIconFolderTextBox" Grid.Row="2" Grid.ColumnSpan="2" Header="OSD icon folder" IsReadOnly="True" />

                            <StackPanel Grid.Row="3" Grid.ColumnSpan="2" Spacing="10">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <Button x:Uid="OpenOsdIconFolderButton" Click="OnOpenOsdIconFolderClick" Content="Open icon folder" Style="{StaticResource SubtleButtonStyle}" />
                                    <Button x:Uid="RefreshOsdIconFolderButton" Click="OnRefreshOsdIconFolderClick" Content="Refresh icons" Style="{StaticResource SubtleButtonStyle}" />
                                </StackPanel>
                                <TextBlock x:Uid="OsdIconSpecText" Style="{StaticResource CardBodyTextBlockStyle}" Text="Icon spec: transparent PNG, square canvas, 256×256 recommended, single-color glyph, and leave some padding near the edge." TextWrapping="WrapWholeWords" />
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <Border x:Name="DeviceCard" Grid.Row="3" Grid.Column="0" Style="{StaticResource PanelCardStyle}">
                    <StackPanel Spacing="14">
                        <TextBlock x:Uid="DeviceCardTitleText" Style="{StaticResource SectionTitleTextBlockStyle}" Text="Device" />

                        <Border Style="{StaticResource SubtlePanelCardStyle}">
                            <StackPanel Spacing="6">
                                <TextBlock x:Uid="SupportedDeviceTitleText" Style="{StaticResource SectionEyebrowTextBlockStyle}" Text="Supported device" />
                                <TextBlock x:Name="SupportedDeviceNameTextBlock" Style="{StaticResource CardTitleTextBlockStyle}" Text="Xiaomi Book Pro 14 2026" />
                                <TextBlock x:Uid="SupportedDeviceDescriptionText" Style="{StaticResource CardBodyTextBlockStyle}" Text="This build is simplified for Xiaomi Book Pro 14 2026 only." TextWrapping="WrapWholeWords" />
                            </StackPanel>
                        </Border>

                        <TextBox x:Uid="ConfigPathTextBox" x:Name="ConfigPathTextBox" Header="Config file" IsReadOnly="True" />

                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Button x:Uid="OpenConfigFolderButton" Click="OnOpenConfigFolderClick" Content="Open config folder" Style="{StaticResource AccentButtonStyle}" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</Page>
