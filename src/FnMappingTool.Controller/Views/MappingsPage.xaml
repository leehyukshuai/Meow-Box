<Page
    x:Class="FnMappingTool.Controller.Views.MappingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:viewModels="using:FnMappingTool.Controller.ViewModels"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="20,16,20,20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="360" MinWidth="300" />
            <ColumnDefinition Width="18" />
            <ColumnDefinition Width="*" MinWidth="560" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Style="{StaticResource PanelCardStyle}">
            <Grid RowSpacing="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Spacing="4">
                    <TextBlock Style="{StaticResource PageTitleTextBlockStyle}" Text="Mappings" />
                    <TextBlock
                        Style="{StaticResource CardBodyTextBlockStyle}"
                        Text="Each mapping connects one captured key to one action."
                        TextWrapping="WrapWholeWords" />
                </StackPanel>

                <ListView
                    x:Name="MappingsListView"
                    Grid.Row="1"
                    ItemsSource="{Binding MappingItems}"
                    SelectedItem="{Binding SelectedMapping, Mode=TwoWay}"
                    SelectionMode="Single">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="2,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <FontIcon
                                    Width="20"
                                    Height="20"
                                    Margin="0,2,12,0"
                                    FontFamily="Segoe Fluent Icons"
                                    FontSize="16"
                                    Glyph="{Binding ActionIconGlyph}" />

                                <StackPanel Grid.Column="1" Spacing="2">
                                    <TextBlock Style="{StaticResource CardTitleTextBlockStyle}" Text="{Binding ListTitle}" />
                                    <TextBlock
                                        Style="{StaticResource CaptionTextBlockStyle}"
                                        Text="{Binding Summary}"
                                        TextWrapping="WrapWholeWords" />
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <Button
                    Grid.Row="2"
                    Click="OnAddMappingClick"
                    HorizontalAlignment="Stretch"
                    Style="{StaticResource AccentButtonStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE710;" />
                        <TextBlock Text="Add Mapping" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <Border Grid.Column="2" Style="{StaticResource PanelCardStyle}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <Grid RowSpacing="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Spacing="4">
                        <TextBlock Style="{StaticResource SectionTitleTextBlockStyle}" Text="Mapping Details" />
                        <TextBlock
                            Style="{StaticResource CardBodyTextBlockStyle}"
                            Text="Pick a key, choose an action category, then select the exact action."
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>

                    <ComboBox
                        Grid.Row="1"
                        DisplayMemberPath="ListTitle"
                        Header="Key"
                        ItemsSource="{Binding KeyItems}"
                        SelectedValue="{Binding SelectedMapping.KeyId, Mode=TwoWay}"
                        SelectedValuePath="Id"
                        SelectionChanged="OnMappingReferenceChanged" />

                    <Grid Grid.Row="2" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="220" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            VerticalAlignment="Center"
                            Style="{StaticResource CardTitleTextBlockStyle}"
                            Text="Action category" />

                        <ComboBox
                            Grid.Column="1"
                            DisplayMemberPath="Label"
                            ItemsSource="{Binding ActionTags}"
                            SelectedItem="{Binding SelectedActionTag, Mode=TwoWay}" />
                    </Grid>

                    <ListView
                        Grid.Row="3"
                        ItemsSource="{Binding FilteredActionOptions}"
                        SelectedItem="{Binding SelectedActionOption, Mode=TwoWay}"
                        SelectionMode="Single">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="viewModels:ActionOptionItemViewModel">
                                <Grid Padding="2,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <FontIcon
                                        Width="20"
                                        Height="20"
                                        Margin="0,2,12,0"
                                        FontFamily="Segoe Fluent Icons"
                                        FontSize="16"
                                        Glyph="{x:Bind IconGlyph, Mode=OneWay}" />

                                    <StackPanel Grid.Column="1" Spacing="2">
                                        <TextBlock Style="{StaticResource CardTitleTextBlockStyle}" Text="{x:Bind Label, Mode=OneWay}" />
                                        <TextBlock
                                            Style="{StaticResource CaptionTextBlockStyle}"
                                            Text="{x:Bind Description, Mode=OneWay}"
                                            TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <InfoBar
                        Grid.Row="4"
                        IsClosable="False"
                        IsOpen="True"
                        Message="{Binding SelectedMapping.Action.ActionDescription, Mode=OneWay}"
                        Severity="Informational"
                        Title="{Binding SelectedMapping.Action.ActionLabel, Mode=OneWay}" />

                    <StackPanel Grid.Row="5" Spacing="16">
                        <StackPanel Spacing="12" Visibility="{Binding SelectedMapping.Action.TargetVisibility}">
                            <TextBox
                                Header="Target"
                                PlaceholderText="Installed app target or executable path"
                                Text="{Binding SelectedMapping.Action.Target, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <StackPanel Orientation="Horizontal" Spacing="12" Visibility="{Binding SelectedMapping.Action.InstalledAppPickerVisibility}">
                                <Button Click="OnPickInstalledAppClick" Content="Choose Installed App" />
                                <Button Click="OnBrowseExecutableClick" Content="Browse File" />
                            </StackPanel>

                            <TextBox
                                Header="Arguments"
                                PlaceholderText="Optional arguments"
                                Text="{Binding SelectedMapping.Action.Arguments, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                Visibility="{Binding SelectedMapping.Action.ArgumentsVisibility}" />
                        </StackPanel>

                        <StackPanel Spacing="12" Visibility="{Binding SelectedMapping.Action.OsdEditorVisibility}">
                            <TextBox
                                Header="OSD title"
                                Text="{Binding SelectedMapping.Action.OsdTitle, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBox
                                Header="OSD message"
                                Text="{Binding SelectedMapping.Action.OsdMessage, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <NumberBox
                                Header="OSD duration (ms)"
                                Minimum="500"
                                SmallChange="100"
                                SpinButtonPlacementMode="Inline"
                                Value="{Binding SelectedMapping.Action.DurationMs, Mode=TwoWay}" />
                            <ComboBox
                                DisplayMemberPath="Label"
                                Header="OSD icon source"
                                ItemsSource="{Binding SelectedMapping.Action.IconModes}"
                                SelectedValue="{Binding SelectedMapping.Action.OsdIconMode, Mode=TwoWay}"
                                SelectedValuePath="Key" />
                            <ComboBox
                                Header="Built-in OSD icon"
                                ItemsSource="{Binding SelectedMapping.Action.OsdBuiltInAssets}"
                                SelectedValue="{Binding SelectedMapping.Action.OsdBuiltInAsset, Mode=TwoWay}"
                                SelectedValuePath="Key"
                                Visibility="{Binding SelectedMapping.Action.OsdBuiltInVisibility}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="10">
                                            <FontIcon FontFamily="Segoe Fluent Icons" Glyph="{Binding IconGlyph}" />
                                            <TextBlock Text="{Binding Label}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <StackPanel Spacing="12" Visibility="{Binding SelectedMapping.Action.OsdCustomVisibility}">
                                <TextBox
                                    Header="Custom OSD icon"
                                    Text="{Binding SelectedMapping.Action.OsdIconPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <Button Click="OnBrowseOsdIconClick" Content="Browse OSD Icon" HorizontalAlignment="Left" />
                            </StackPanel>
                        </StackPanel>

                    </StackPanel>

                    <StackPanel Grid.Row="6" Orientation="Horizontal" Spacing="12">
                        <Button
                            Click="OnSaveMappingClick"
                            HorizontalAlignment="Left"
                            Style="{StaticResource AccentButtonStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE74E;" />
                                <TextBlock Text="Save Mapping" />
                            </StackPanel>
                        </Button>

                        <Button Click="OnDeleteMappingClick" HorizontalAlignment="Left">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE74D;" />
                                <TextBlock Text="Delete Mapping" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>
