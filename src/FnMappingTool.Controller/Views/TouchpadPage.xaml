<Page
    x:Class="FnMappingTool.Controller.Views.TouchpadPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <DataTemplate x:Key="TouchpadActionEditorTemplate">
            <Border Style="{StaticResource SubtlePanelCardStyle}">
                <StackPanel Spacing="14">
                    <StackPanel Spacing="4">
                        <TextBlock
                            Style="{StaticResource CardTitleTextBlockStyle}"
                            Text="{Binding Title}" />
                        <TextBlock
                            Style="{StaticResource CardBodyTextBlockStyle}"
                            Text="{Binding Description}"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button
                            Click="OnChooseTouchpadActionClick"
                            Content="Choose action"
                            Style="{StaticResource SubtleButtonStyle}" />
                        <Button
                            Click="OnClearTouchpadActionClick"
                            Content="Clear action"
                            IsEnabled="{Binding Action.HasAssignedAction}"
                            Style="{StaticResource SubtleButtonStyle}" />
                    </StackPanel>

                    <Border
                        Style="{StaticResource SubtlePanelCardStyle}"
                        Visibility="{Binding Action.HasAssignedActionVisibility}">
                        <StackPanel Spacing="12">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border
                                    Width="32"
                                    Height="32"
                                    Background="{StaticResource ShellInfoSoftBrush}"
                                    CornerRadius="8">
                                    <FontIcon
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontFamily="Segoe Fluent Icons"
                                        FontSize="14"
                                        Glyph="{Binding ActionIconGlyph}" />
                                </Border>

                                <StackPanel Grid.Column="1" Spacing="4">
                                    <TextBlock
                                        Style="{StaticResource CardTitleTextBlockStyle}"
                                        Text="{Binding ActionSummary}" />
                                    <TextBlock
                                        Style="{StaticResource CardBodyTextBlockStyle}"
                                        Text="{Binding ActionDescription}"
                                        TextWrapping="WrapWholeWords" />
                                </StackPanel>
                            </Grid>

                            <StackPanel
                                Spacing="12"
                                Visibility="{Binding Action.TargetVisibility}">
                                <TextBox
                                    Header="Target"
                                    LostFocus="OnTouchpadEditorLostFocus"
                                    PlaceholderText="Installed app target or executable path"
                                    Text="{Binding Action.Target, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <StackPanel
                                    Orientation="Horizontal"
                                    Spacing="12"
                                    Visibility="{Binding Action.InstalledAppPickerVisibility}">
                                    <Button
                                        Click="OnPickInstalledAppClick"
                                        Content="Choose app"
                                        Style="{StaticResource SubtleButtonStyle}" />
                                    <Button
                                        Click="OnBrowseExecutableClick"
                                        Content="Browse file"
                                        Style="{StaticResource SubtleButtonStyle}" />
                                </StackPanel>
                                <TextBox
                                    Header="Arguments"
                                    LostFocus="OnTouchpadEditorLostFocus"
                                    PlaceholderText="Optional launch arguments"
                                    Text="{Binding Action.Arguments, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Visibility="{Binding Action.ArgumentsVisibility}" />
                            </StackPanel>

                            <StackPanel
                                Spacing="12"
                                Visibility="{Binding Action.StandardKeyEditorVisibility}">
                                <TextBlock
                                    Style="{StaticResource CardTitleTextBlockStyle}"
                                    Text="Standard key" />
                                <TextBlock
                                    Style="{StaticResource CardBodyTextBlockStyle}"
                                    Text="Choose the standard keyboard or media key that should be emitted."
                                    TextWrapping="WrapWholeWords" />
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="220" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <ComboBox
                                        DisplayMemberPath="Label"
                                        Header="Group"
                                        ItemsSource="{Binding StandardKeyGroups}"
                                        SelectedValue="{Binding Action.StandardKeyGroup, Mode=TwoWay}"
                                        SelectedValuePath="Key"
                                        SelectionChanged="OnTouchpadStandardKeyGroupSelectionChanged" />
                                    <ComboBox
                                        Grid.Column="1"
                                        DisplayMemberPath="Label"
                                        Header="Key"
                                        ItemsSource="{Binding FilteredStandardKeys}"
                                        SelectedValue="{Binding Action.StandardKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        SelectedValuePath="Key"
                                        SelectionChanged="OnTouchpadActionSelectionChanged" />
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </DataTemplate>
    </Page.Resources>

    <ScrollViewer HorizontalScrollBarVisibility="Disabled">
        <Grid Padding="{StaticResource AppPagePadding}" RowSpacing="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border
                Grid.Row="0"
                Style="{StaticResource PanelCardStyle}">
                <Grid RowSpacing="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            Style="{StaticResource SectionTitleTextBlockStyle}"
                            Text="Touchpad surface" />

                        <Border
                            Grid.Column="1"
                            Background="{ThemeResource LayerFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="999"
                            Padding="10,5">
                            <TextBlock
                                Style="{StaticResource CaptionTextBlockStyle}"
                                Text="{Binding Touchpad.SurfaceSizeLabel}" />
                        </Border>

                        <Button
                            Grid.Column="2"
                            Click="OnTouchpadSurfaceToggleClick"
                            Style="{StaticResource SubtleButtonStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="{x:Bind SurfaceToggleLabel, Mode=OneWay}" />
                                <FontIcon
                                    FontFamily="Segoe Fluent Icons"
                                    Glyph="{x:Bind SurfaceToggleGlyph, Mode=OneWay}" />
                            </StackPanel>
                        </Button>
                    </Grid>

                    <Border
                        Grid.Row="1"
                        Background="{ThemeResource LayerFillColorAltBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="18"
                        Padding="16"
                        Visibility="{x:Bind SurfaceContentVisibility, Mode=OneWay}">
                        <Grid
                            x:Name="TouchpadVisualizerLayoutGrid"
                            ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Grid>
                                <Canvas
                                    x:Name="TouchpadCanvas"
                                    MinHeight="320"
                                    SizeChanged="OnTouchpadCanvasSizeChanged" />
                            </Grid>

                            <Border
                                Grid.Column="1"
                                Background="{ThemeResource LayerFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="10"
                                MinWidth="280">
                                <StackPanel Spacing="8">
                                    <TextBlock
                                        Style="{StaticResource CardTitleTextBlockStyle}"
                                        Text="Contacts" />
                                    <ItemsControl ItemsSource="{x:Bind VisibleContacts, Mode=OneWay}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border
                                                    Background="{ThemeResource LayerFillColorAltBrush}"
                                                    CornerRadius="10"
                                                    Padding="8">
                                                    <Grid ColumnSpacing="6">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>

                                                        <Border
                                                            Background="{ThemeResource LayerFillColorDefaultBrush}"
                                                            CornerRadius="8"
                                                            Padding="8,6">
                                                            <TextBlock
                                                                FontSize="12"
                                                                FontWeight="SemiBold"
                                                                Text="{Binding Label}" />
                                                        </Border>

                                                        <Border
                                                            Grid.Column="1"
                                                            Background="{ThemeResource LayerFillColorDefaultBrush}"
                                                            CornerRadius="8"
                                                            Padding="8,6">
                                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                                <TextBlock FontSize="11" Opacity="0.72" Text="X" />
                                                                <TextBlock FontSize="12" FontWeight="SemiBold" Text="{Binding X}" />
                                                            </StackPanel>
                                                        </Border>

                                                        <Border
                                                            Grid.Column="2"
                                                            Background="{ThemeResource LayerFillColorDefaultBrush}"
                                                            CornerRadius="8"
                                                            Padding="8,6">
                                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                                <TextBlock FontSize="11" Opacity="0.72" Text="Y" />
                                                                <TextBlock FontSize="12" FontWeight="SemiBold" Text="{Binding Y}" />
                                                            </StackPanel>
                                                        </Border>

                                                        <Border
                                                            Grid.Column="3"
                                                            Background="{ThemeResource LayerFillColorDefaultBrush}"
                                                            CornerRadius="8"
                                                            Padding="8,6">
                                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                                <TextBlock FontSize="11" Opacity="0.72" Text="P" />
                                                                <TextBlock FontSize="12" FontWeight="SemiBold" Text="{Binding Pressure}" />
                                                            </StackPanel>
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <StackPanel
                                x:Name="TouchpadCanvasEmptyStatePanel"
                                Grid.ColumnSpan="2"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Spacing="8">
                                <FontIcon
                                    FontFamily="Segoe Fluent Icons"
                                    Style="{StaticResource EmptyStateIconStyle}"
                                    Glyph="&#xE7F4;" />
                                <TextBlock
                                    x:Uid="TouchpadVisualizerEmptyTitleText"
                                    Style="{StaticResource EmptyStateTitleTextBlockStyle}"
                                    Text="Waiting for touchpad input" />
                                <TextBlock
                                    x:Uid="TouchpadVisualizerEmptyBodyText"
                                    Style="{StaticResource EmptyStateBodyTextBlockStyle}"
                                    Text="Start the service and touch the pad to see live contact pressure."
                                    TextWrapping="WrapWholeWords" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <Border
                Grid.Row="1"
                Style="{StaticResource SubtlePanelCardStyle}">
                <StackPanel Spacing="14">
                    <StackPanel Spacing="4">
                        <TextBlock
                            Style="{StaticResource SectionTitleTextBlockStyle}"
                            Text="Global action" />
                        <TextBlock
                            Style="{StaticResource CardBodyTextBlockStyle}"
                            Text="Use the built-in touchpad pressure states to trigger a global action."
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>

                    <ContentControl
                        Content="{Binding Touchpad.GlobalDeepPress}"
                        ContentTemplate="{StaticResource TouchpadActionEditorTemplate}" />
                </StackPanel>
            </Border>

            <Border
                Grid.Row="2"
                Style="{StaticResource SubtlePanelCardStyle}">
                <StackPanel Spacing="14">
                    <StackPanel Spacing="6">
                        <TextBlock
                            Style="{StaticResource SectionTitleTextBlockStyle}"
                            Text="{Binding Touchpad.LeftTopCorner.Title}" />
                        <TextBlock
                            Style="{StaticResource CardBodyTextBlockStyle}"
                            Text="{Binding Touchpad.LeftTopCorner.Description}"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>

                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border
                            Background="{ThemeResource LayerFillColorAltBrush}"
                            CornerRadius="10"
                            Padding="10,8">
                            <TextBlock
                                Style="{StaticResource CaptionTextBlockStyle}"
                                Text="{Binding Touchpad.LeftTopCorner.BoundsSummary}" />
                        </Border>

                        <TextBlock
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            Style="{StaticResource CardBodyTextBlockStyle}"
                            Text="{Binding Touchpad.LeftTopCorner.PriorityHint}"
                            TextWrapping="WrapWholeWords" />
                    </Grid>

                    <ContentControl
                        Content="{Binding Touchpad.LeftTopCorner.DeepPress}"
                        ContentTemplate="{StaticResource TouchpadActionEditorTemplate}" />
                    <ContentControl
                        Content="{Binding Touchpad.LeftTopCorner.LongPress}"
                        ContentTemplate="{StaticResource TouchpadActionEditorTemplate}" />
                </StackPanel>
            </Border>

            <Border
                Grid.Row="3"
                Style="{StaticResource SubtlePanelCardStyle}">
                <StackPanel Spacing="14">
                    <StackPanel Spacing="6">
                        <TextBlock
                            Style="{StaticResource SectionTitleTextBlockStyle}"
                            Text="{Binding Touchpad.RightTopCorner.Title}" />
                        <TextBlock
                            Style="{StaticResource CardBodyTextBlockStyle}"
                            Text="{Binding Touchpad.RightTopCorner.Description}"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>

                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border
                            Background="{ThemeResource LayerFillColorAltBrush}"
                            CornerRadius="10"
                            Padding="10,8">
                            <TextBlock
                                Style="{StaticResource CaptionTextBlockStyle}"
                                Text="{Binding Touchpad.RightTopCorner.BoundsSummary}" />
                        </Border>

                        <TextBlock
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            Style="{StaticResource CardBodyTextBlockStyle}"
                            Text="{Binding Touchpad.RightTopCorner.PriorityHint}"
                            TextWrapping="WrapWholeWords" />
                    </Grid>

                    <ContentControl
                        Content="{Binding Touchpad.RightTopCorner.DeepPress}"
                        ContentTemplate="{StaticResource TouchpadActionEditorTemplate}" />
                    <ContentControl
                        Content="{Binding Touchpad.RightTopCorner.LongPress}"
                        ContentTemplate="{StaticResource TouchpadActionEditorTemplate}" />
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
