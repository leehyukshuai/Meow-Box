<Page
    x:Class="FnMappingTool.Controller.Views.TouchpadPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <DataTemplate x:Key="TouchpadActionEditorTemplate">
            <Border
                HorizontalAlignment="Stretch"
                Style="{StaticResource SubtlePanelCardStyle}">
                <StackPanel Spacing="14">
                    <StackPanel Spacing="8">
                        <TextBlock
                            Style="{StaticResource CardTitleTextBlockStyle}"
                            Text="{Binding Title}" />
                        <TextBlock
                            Style="{StaticResource CardBodyTextBlockStyle}"
                            Text="{Binding Description}"
                            TextWrapping="WrapWholeWords" />
                        <ItemsControl
                            ItemsSource="{Binding GuidanceLines}"
                            Visibility="{Binding GuidanceVisibility}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock
                                        Margin="0,0,0,2"
                                        Style="{StaticResource CaptionTextBlockStyle}"
                                        Text="{Binding}"
                                        TextWrapping="WrapWholeWords" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button
                            Click="OnChooseTouchpadActionClick"
                            Content="Choose action"
                            Style="{StaticResource SubtleButtonStyle}" />
                        <Button
                            Click="OnClearTouchpadActionClick"
                            Content="Clear action"
                            IsEnabled="{Binding Action.HasAssignedAction}"
                            Style="{StaticResource SubtleButtonStyle}" />
                    </StackPanel>

                    <Border
                        Style="{StaticResource SubtlePanelCardStyle}"
                        Visibility="{Binding Action.HasAssignedActionVisibility}">
                        <StackPanel Spacing="12">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border
                                    Width="32"
                                    Height="32"
                                    Background="{StaticResource ShellInfoSoftBrush}"
                                    CornerRadius="8">
                                    <FontIcon
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontFamily="Segoe Fluent Icons"
                                        FontSize="14"
                                        Glyph="{Binding ActionIconGlyph}" />
                                </Border>

                                <StackPanel Grid.Column="1" Spacing="4">
                                    <TextBlock
                                        Style="{StaticResource CardTitleTextBlockStyle}"
                                        Text="{Binding ActionSummary}" />
                                    <TextBlock
                                        Style="{StaticResource CardBodyTextBlockStyle}"
                                        Text="{Binding ActionDescription}"
                                        TextWrapping="WrapWholeWords" />
                                </StackPanel>
                            </Grid>

                            <StackPanel
                                Spacing="12"
                                Visibility="{Binding Action.TargetVisibility}">
                                <TextBox
                                    Header="Target"
                                    LostFocus="OnTouchpadEditorLostFocus"
                                    PlaceholderText="Installed app target or executable path"
                                    Text="{Binding Action.Target, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <StackPanel
                                    Orientation="Horizontal"
                                    Spacing="12"
                                    Visibility="{Binding Action.InstalledAppPickerVisibility}">
                                    <Button
                                        Click="OnPickInstalledAppClick"
                                        Content="Choose app"
                                        Style="{StaticResource SubtleButtonStyle}" />
                                    <Button
                                        Click="OnBrowseExecutableClick"
                                        Content="Browse file"
                                        Style="{StaticResource SubtleButtonStyle}" />
                                </StackPanel>
                                <TextBox
                                    Header="Arguments"
                                    LostFocus="OnTouchpadEditorLostFocus"
                                    PlaceholderText="Optional launch arguments"
                                    Text="{Binding Action.Arguments, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Visibility="{Binding Action.ArgumentsVisibility}" />
                            </StackPanel>

                            <StackPanel
                                Spacing="12"
                                Visibility="{Binding Action.StandardKeyEditorVisibility}">
                                <TextBlock
                                    Style="{StaticResource CardTitleTextBlockStyle}"
                                    Text="Standard key" />
                                <TextBlock
                                    Style="{StaticResource CardBodyTextBlockStyle}"
                                    Text="Choose the standard keyboard or media key that should be emitted."
                                    TextWrapping="WrapWholeWords" />
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="220" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <ComboBox
                                        DisplayMemberPath="Label"
                                        Header="Group"
                                        Loaded="OnTouchpadStandardKeyGroupComboBoxLoaded"
                                        Unloaded="OnTouchpadStandardKeyComboBoxUnloaded"
                                        ItemsSource="{Binding StandardKeyGroups}"
                                        SelectedValue="{Binding Action.StandardKeyGroup, Mode=TwoWay}"
                                        SelectedValuePath="Key"
                                        SelectionChanged="OnTouchpadStandardKeyGroupSelectionChanged" />
                                    <ComboBox
                                        Grid.Column="1"
                                        DisplayMemberPath="Label"
                                        Header="Key"
                                        Loaded="OnTouchpadStandardKeyComboBoxLoaded"
                                        Unloaded="OnTouchpadStandardKeyComboBoxUnloaded"
                                        ItemsSource="{Binding FilteredStandardKeys}"
                                        SelectedValue="{Binding Action.StandardKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        SelectedValuePath="Key"
                                        SelectionChanged="OnTouchpadActionSelectionChanged" />
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </DataTemplate>
    </Page.Resources>

    <ScrollViewer HorizontalScrollBarVisibility="Disabled">
        <Grid Padding="{StaticResource AppPagePadding}" RowSpacing="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border
                Grid.Row="0"
                Style="{StaticResource PanelCardStyle}">
                <Border
                    Background="{ThemeResource LayerFillColorAltBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="18"
                    Padding="16">
                    <Grid
                        x:Name="TouchpadVisualizerLayoutGrid"
                        ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Grid
                            x:Name="TouchpadPreviewHost"
                            Width="500"
                            Height="324"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top">
                            <Canvas
                                x:Name="TouchpadCanvas"
                                SizeChanged="OnTouchpadCanvasSizeChanged" />

                            <StackPanel
                                x:Name="TouchpadCanvasEmptyStatePanel"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Spacing="8">
                                <FontIcon
                                    FontFamily="Segoe Fluent Icons"
                                    Style="{StaticResource EmptyStateIconStyle}"
                                    Glyph="&#xE7F4;" />
                                <TextBlock
                                    x:Uid="TouchpadVisualizerEmptyTitleText"
                                    Style="{StaticResource EmptyStateTitleTextBlockStyle}"
                                    Text="Waiting for touchpad input" />
                                <TextBlock
                                    x:Uid="TouchpadVisualizerEmptyBodyText"
                                    Style="{StaticResource EmptyStateBodyTextBlockStyle}"
                                    Text="Start the service and touch the pad to see live contact pressure."
                                    TextWrapping="WrapWholeWords" />
                            </StackPanel>
                        </Grid>

                        <StackPanel
                            x:Name="TouchpadGuidancePanel"
                            Grid.Column="1"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Center"
                            Spacing="8">
                            <TextBlock
                                Style="{StaticResource CardBodyTextBlockStyle}"
                                Text="• 你可以为触控板的重按设置一个自定义动作。"
                                TextWrapping="WrapWholeWords" />
                            <TextBlock
                                Style="{StaticResource CardBodyTextBlockStyle}"
                                Text="• LT 和 RT 区域也可以分别设置重按和长按两种动作。"
                                TextWrapping="WrapWholeWords" />
                            <TextBlock
                                Style="{StaticResource CardBodyTextBlockStyle}"
                                Text="• LT 和 RT 区域的重按会覆盖全局的重按触发动作。"
                                TextWrapping="WrapWholeWords" />
                            <TextBlock
                                Style="{StaticResource CardBodyTextBlockStyle}"
                                Text="• 长按需要的触发时间可以在设置页面当中设置。"
                                TextWrapping="WrapWholeWords" />
                        </StackPanel>

                    </Grid>
                </Border>
            </Border>

            <Grid
                Grid.Row="1"
                ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="320" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border
                    Grid.Column="0"
                    Style="{StaticResource PanelCardStyle}">
                    <ListView
                        Style="{StaticResource ListHostStyle}"
                        ItemContainerStyle="{StaticResource ListHostItemStyle}"
                        ItemsSource="{Binding Touchpad.AllActionEditors}"
                        SelectedItem="{Binding Touchpad.SelectedActionEditor, Mode=TwoWay}"
                        SelectionMode="Single">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Border Width="28" Height="28" Background="{StaticResource ShellInfoSoftBrush}" CornerRadius="6">
                                        <FontIcon HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe Fluent Icons" FontSize="12" Glyph="{Binding ActionIconGlyph}" />
                                    </Border>

                                    <StackPanel Grid.Column="1" Spacing="2">
                                        <TextBlock Style="{StaticResource CardTitleTextBlockStyle}" Text="{Binding Title}" />
                                        <TextBlock Style="{StaticResource CaptionTextBlockStyle}" Text="{Binding ActionSummary}" TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Border>

                <Border
                    Grid.Column="1"
                    Style="{StaticResource PanelCardStyle}">
                    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                        <ContentControl
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Stretch"
                            Content="{Binding Touchpad.SelectedActionEditor}"
                            ContentTemplate="{StaticResource TouchpadActionEditorTemplate}" />
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</Page>
