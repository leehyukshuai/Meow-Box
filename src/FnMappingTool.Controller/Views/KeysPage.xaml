<Page
    x:Class="FnMappingTool.Controller.Views.KeysPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="{StaticResource AppPagePadding}">
        <Grid
            x:Name="PageLayoutGrid"
            ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border
                x:Name="KeysListPane"
                Grid.Column="0"
                Style="{StaticResource PanelCardStyle}">
                <Grid RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            x:Uid="KeysPageSavedKeysText"
                            Style="{StaticResource SectionTitleTextBlockStyle}"
                            Text="Saved keys" />

                        <Button
                            Grid.Column="1"
                            Click="OnAddKeyClick"
                            Style="{StaticResource AccentButtonStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE710;" />
                                <TextBlock
                                    x:Uid="KeysPageCaptureButtonText"
                                    Text="Capture key" />
                            </StackPanel>
                        </Button>
                    </Grid>

                    <ListView
                        x:Name="KeysListView"
                        Grid.Row="1"
                        Style="{StaticResource ListHostStyle}"
                        ItemContainerStyle="{StaticResource ListHostItemStyle}"
                        ItemsSource="{Binding KeyItems}"
                        SelectedItem="{Binding SelectedKey, Mode=TwoWay}"
                        SelectionMode="Single">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <Border
                                        Width="28"
                                        Height="28"
                                        Background="{StaticResource ShellAccentSoftBrush}"
                                        CornerRadius="6">
                                        <FontIcon
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            FontFamily="Segoe Fluent Icons"
                                            FontSize="12"
                                            Glyph="&#xE765;" />
                                    </Border>

                                    <StackPanel Spacing="2">
                                        <TextBlock Style="{StaticResource CardTitleTextBlockStyle}" Text="{Binding ListTitle}" />
                                        <TextBlock
                                            x:Uid="KeysPageCapturedVendorEventText"
                                            Style="{StaticResource CaptionTextBlockStyle}"
                                            Text="Captured vendor event" />
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <StackPanel
                        x:Name="KeysEmptyStatePanel"
                        Grid.Row="1"
                        Style="{StaticResource EmptyStatePanelStyle}"
                        Visibility="Collapsed">
                        <FontIcon
                            FontFamily="Segoe Fluent Icons"
                            Style="{StaticResource EmptyStateIconStyle}"
                            Glyph="&#xE765;" />
                        <TextBlock
                            x:Uid="KeysPageEmptyTitleText"
                            Style="{StaticResource EmptyStateTitleTextBlockStyle}"
                            Text="No keys yet" />
                        <TextBlock
                            x:Uid="KeysPageEmptyBodyText"
                            Style="{StaticResource EmptyStateBodyTextBlockStyle}"
                            Text="Capture a key to get started." />
                    </StackPanel>
                </Grid>
            </Border>

            <Border
                x:Name="KeyDetailsPane"
                Grid.Column="1"
                Style="{StaticResource PanelCardStyle}">
                <Grid>
                    <Grid
                        x:Name="KeyDetailsContentPanel"
                        RowSpacing="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock
                                x:Uid="KeyDetailsTitleText"
                                Style="{StaticResource SectionTitleTextBlockStyle}"
                                Text="Key details" />

                            <Button
                                Grid.Column="1"
                                Click="OnDeleteKeyClick"
                                Style="{StaticResource DangerButtonStyle}">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE74D;" />
                                    <TextBlock
                                        x:Uid="KeyDeleteButtonText"
                                        Text="Delete" />
                                </StackPanel>
                            </Button>
                        </Grid>

                        <TextBox
                            x:Uid="KeyNameTextBox"
                            Grid.Row="1"
                            Header="Name"
                            LostFocus="OnKeyNameLostFocus"
                            PlaceholderText="Key name"
                            Text="{Binding SelectedKey.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBox
                            x:Uid="KeyTriggerTextBox"
                            Grid.Row="2"
                            AcceptsReturn="True"
                            FontFamily="Consolas"
                            Header="Captured event"
                            IsReadOnly="True"
                            MinHeight="240"
                            Text="{Binding SelectedKey.TriggerDetails, Mode=OneWay}"
                            TextWrapping="Wrap" />
                    </Grid>

                    <StackPanel
                        x:Name="KeyDetailsEmptyStatePanel"
                        Style="{StaticResource EmptyStatePanelStyle}"
                        Visibility="Collapsed">
                        <FontIcon
                            FontFamily="Segoe Fluent Icons"
                            Style="{StaticResource EmptyStateIconStyle}"
                            Glyph="&#xE8FD;" />
                        <TextBlock
                            x:Uid="KeyDetailsEmptyTitleText"
                            Style="{StaticResource EmptyStateTitleTextBlockStyle}"
                            Text="No key selected" />
                        <TextBlock
                            x:Uid="KeyDetailsEmptyBodyText"
                            Style="{StaticResource EmptyStateBodyTextBlockStyle}"
                            Text="Pick a key from the list or capture a new one." />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>