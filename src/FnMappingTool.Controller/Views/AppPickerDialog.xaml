<ContentDialog
    x:Class="FnMappingTool.Controller.Views.AppPickerDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    PrimaryButtonText="Choose"
    CloseButtonText="Cancel"
    DefaultButton="Primary"
    mc:Ignorable="d">

    <StackPanel Width="520" Spacing="14">
        <TextBox
            x:Name="SearchTextBox"
            Header="Search installed apps"
            PlaceholderText="Type part of the app name"
            TextChanged="OnSearchTextChanged" />

        <InfoBar
            x:Name="LoadingInfoBar"
            IsClosable="False"
            IsOpen="True"
            Severity="Informational"
            Title="Installed apps" />

        <ListView
            x:Name="AppsListView"
            Height="360"
            SelectionMode="Single"
            SelectionChanged="OnSelectionChanged">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <StackPanel Padding="4,8" Spacing="2">
                        <TextBlock Text="{Binding Name}" />
                        <TextBlock Opacity="0.65" Text="{Binding AppId}" TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </StackPanel>
</ContentDialog>
