<ContentDialog
    x:Class="FnMappingTool.Controller.Views.AddKeyDialog"
    x:Uid="AddKeyDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    PrimaryButtonText="Add key"
    CloseButtonText="Cancel"
    DefaultButton="Primary"
    mc:Ignorable="d">

    <ContentDialog.Resources>
        <Style TargetType="Button" BasedOn="{StaticResource AccentTextButtonStyle}" />
    </ContentDialog.Resources>

    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <StackPanel Width="430" Spacing="12">
            <StackPanel Spacing="4">
                <TextBlock x:Uid="AddKeyCaptureEyebrowText" Style="{StaticResource SectionEyebrowTextBlockStyle}" Text="Capture" />
                <TextBlock x:Uid="AddKeyTitleText" Style="{StaticResource SectionTitleTextBlockStyle}" Text="Capture a hardware key" />
                <TextBlock x:Uid="AddKeyDescriptionText" Style="{StaticResource CardBodyTextBlockStyle}" Text="Click Start capture, press the hardware key, then name it." TextWrapping="WrapWholeWords" />
            </StackPanel>

            <Border Style="{StaticResource SubtlePanelCardStyle}">
                <StackPanel Spacing="12">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Width="40" Height="40" Background="{StaticResource ShellAccentSoftBrush}" CornerRadius="10">
                            <FontIcon HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe Fluent Icons" FontSize="18" Glyph="&#xE765;" />
                        </Border>

                        <StackPanel Grid.Column="1" Spacing="4">
                            <TextBlock x:Uid="AddKeyCaptureCardTitleText" Style="{StaticResource CardTitleTextBlockStyle}" Text="Start capture" />
                            <TextBlock x:Uid="AddKeyCaptureCardBodyText" Style="{StaticResource CardBodyTextBlockStyle}" Text="Press the button below. The next hardware key you press will be captured." TextWrapping="WrapWholeWords" />
                        </StackPanel>
                    </Grid>

                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button x:Name="StartCaptureButton" Click="OnStartCaptureClick" Style="{StaticResource AccentButtonStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE765;" />
                                <TextBlock x:Uid="StartCaptureButtonText" Text="Start capture" />
                            </StackPanel>
                        </Button>

                        <Border x:Name="CaptureStatusBadge" Width="40" Height="40" Background="{ThemeResource LayerFillColorAltBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" VerticalAlignment="Center">
                            <Grid>
                                <FontIcon x:Name="CaptureStatusIcon" HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe Fluent Icons" FontSize="16" Glyph="&#xE946;" />
                                <ProgressRing x:Name="CaptureProgressRing" Width="18" Height="18" IsActive="False" Visibility="Collapsed" />
                            </Grid>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border x:Name="KeyNameCard" Style="{StaticResource SubtlePanelCardStyle}" Visibility="Collapsed">
                <StackPanel Spacing="8">
                    <TextBlock x:Uid="AddKeyNameLabelText" Style="{StaticResource CardTitleTextBlockStyle}" Text="Name this key" />
                    <TextBox x:Uid="AddKeyNameTextBox" x:Name="NameTextBox" PlaceholderText="Enter a name for this key" TextChanged="OnNameTextChanged" />
                    <TextBlock x:Name="NameValidationTextBlock" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemFillColorCriticalBrush}" TextWrapping="WrapWholeWords" Visibility="Collapsed" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</ContentDialog>
