<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="AppTitleBarBackgroundBrush" Color="{ThemeResource LayerFillColorAltBrush.Color}" />
    <SolidColorBrush x:Key="ShellChromeBrush" Color="{ThemeResource LayerFillColorDefaultBrush.Color}" />
    <SolidColorBrush x:Key="ShellSubtleBrush" Color="{ThemeResource LayerFillColorAltBrush.Color}" />
    <SolidColorBrush x:Key="ShellAccentSoftBrush" Color="#1F4CC473" />
    <SolidColorBrush x:Key="ShellInfoSoftBrush" Color="#1F4A90E2" />

    <CornerRadius x:Key="CardCornerRadius">22</CornerRadius>
    <CornerRadius x:Key="SmallCardCornerRadius">16</CornerRadius>

    <Thickness x:Key="AppPagePadding">24,20,24,24</Thickness>

    <Style x:Key="TitleBarTitleTextBlockStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}" />
    </Style>

    <Style x:Key="TitleBarSubtitleTextBlockStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
    </Style>

    <Style x:Key="ShellHeadlineTextBlockStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="20" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}" />
    </Style>

    <Style x:Key="ShellCaptionTextBlockStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
    </Style>

    <Style x:Key="CaptionTextBlockStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
    </Style>

    <Style x:Key="PageTitleTextBlockStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="30" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}" />
    </Style>

    <Style x:Key="PageSubtitleTextBlockStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
    </Style>

    <Style x:Key="SectionTitleTextBlockStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="20" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}" />
    </Style>

    <Style x:Key="SectionEyebrowTextBlockStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="CharacterSpacing" Value="40" />
        <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
    </Style>

    <Style x:Key="CardTitleTextBlockStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}" />
    </Style>

    <Style x:Key="CardBodyTextBlockStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
    </Style>

    <Style x:Key="HeroValueTextBlockStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="34" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}" />
    </Style>

    <Style x:Key="BadgeBorderStyle" TargetType="Border">
        <Setter Property="Padding" Value="10,4" />
        <Setter Property="CornerRadius" Value="999" />
        <Setter Property="Background" Value="{StaticResource ShellSubtleBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource DividerStrokeColorDefaultBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style x:Key="PanelCardStyle" TargetType="Border">
        <Setter Property="Padding" Value="22" />
        <Setter Property="CornerRadius" Value="{StaticResource CardCornerRadius}" />
        <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style x:Key="SubtlePanelCardStyle" TargetType="Border" BasedOn="{StaticResource PanelCardStyle}">
        <Setter Property="Background" Value="{StaticResource ShellSubtleBrush}" />
    </Style>

    <Style x:Key="HeroPanelCardStyle" TargetType="Border" BasedOn="{StaticResource PanelCardStyle}">
        <Setter Property="Background" Value="{ThemeResource AcrylicInAppFillColorDefaultBrush}" />
        <Setter Property="Padding" Value="24" />
    </Style>

    <Style x:Key="StatCardStyle" TargetType="Border" BasedOn="{StaticResource SubtlePanelCardStyle}">
        <Setter Property="Padding" Value="18" />
        <Setter Property="CornerRadius" Value="{StaticResource SmallCardCornerRadius}" />
    </Style>

    <Style x:Key="ListHostStyle" TargetType="ListView">
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <Style x:Key="GridHostStyle" TargetType="GridView">
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="IsItemClickEnabled" Value="True" />
    </Style>

    <Style x:Key="AccentTextButtonStyle" TargetType="Button">
        <Setter Property="Padding" Value="14,8" />
    </Style>

    <Style x:Key="PrimaryPillButtonStyle" TargetType="Button" BasedOn="{StaticResource AccentTextButtonStyle}">
        <Setter Property="CornerRadius" Value="999" />
    </Style>

    <Style x:Key="SubtleButtonStyle" TargetType="Button">
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="CornerRadius" Value="12" />
    </Style>
</ResourceDictionary>
