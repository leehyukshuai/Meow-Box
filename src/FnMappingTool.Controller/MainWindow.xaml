<Window
    x:Class="FnMappingTool.Controller.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Fn Mapping Tool">

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid
            x:Name="AppTitleBar"
            Grid.Row="0"
            Background="{ThemeResource AppTitleBarBackgroundBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel
                Margin="18,0,0,0"
                VerticalAlignment="Center"
                Orientation="Horizontal"
                Spacing="10">
                <TextBlock
                    VerticalAlignment="Center"
                    Style="{StaticResource TitleBarTitleTextBlockStyle}"
                    Text="Fn Mapping Tool" />

                <Grid
                    x:Name="ServiceStatusLight"
                    Width="18"
                    Height="18"
                    VerticalAlignment="Center">
                    <Ellipse
                        x:Name="ServiceStatusGlow"
                        Width="18"
                        Height="18"
                        Fill="#44FF6F61" />
                    <Ellipse
                        x:Name="ServiceStatusCoreOuter"
                        Width="12"
                        Height="12"
                        Fill="#CCFF6F61" />
                    <Ellipse
                        x:Name="ServiceStatusCoreInner"
                        Width="8"
                        Height="8"
                        Fill="#FFFF6F61" />
                    <ToolTipService.ToolTip>
                        <ToolTip x:Name="ServiceStatusToolTip" Content="Background service stopped" />
                    </ToolTipService.ToolTip>
                </Grid>
            </StackPanel>
        </Grid>

        <NavigationView
            x:Name="ShellNavigationView"
            Grid.Row="1"
            AlwaysShowHeader="False"
            CompactPaneLength="44"
            IsBackButtonVisible="Collapsed"
            IsPaneToggleButtonVisible="True"
            IsSettingsVisible="True"
            OpenPaneLength="164"
            PaneDisplayMode="Auto"
            SelectionChanged="OnNavigationSelectionChanged">

            <NavigationView.MenuItems>
                <NavigationViewItem
                    x:Name="KeysItem"
                    Content="Keys"
                    Icon="Keyboard"
                    Tag="keys" />
                <NavigationViewItem
                    x:Name="MappingsItem"
                    Content="Mappings"
                    Icon="Switch"
                    Tag="mappings" />
            </NavigationView.MenuItems>

            <Frame x:Name="ContentFrame" />
        </NavigationView>
    </Grid>
</Window>
