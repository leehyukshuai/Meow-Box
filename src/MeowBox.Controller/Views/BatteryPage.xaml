<Page
    x:Class="MeowBox.Controller.Views.BatteryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer HorizontalScrollBarVisibility="Disabled">
        <Grid Padding="{StaticResource AppPagePadding}" RowSpacing="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

                <InfoBar
                    x:Name="RuntimeNoticeInfoBar"
                    Grid.Row="0"
                    IsClosable="False"
                    IsOpen="False"
                    Severity="Informational">
                    <InfoBar.ActionButton>
                        <Button
                            x:Uid="BatteryRefreshButton"
                            x:Name="RefreshButton"
                            Click="OnRefreshButtonClick"
                            Content="Refresh"
                            Style="{StaticResource SubtleButtonStyle}" />
                    </InfoBar.ActionButton>
                </InfoBar>

                <Border
                    x:Name="PerformanceCard"
                    Grid.Row="1"
                    Visibility="Collapsed"
                    Style="{StaticResource PanelCardStyle}">
                    <StackPanel Spacing="14">
                        <TextBlock
                            x:Uid="BatteryPerformanceTitleText"
                            Style="{StaticResource SectionTitleTextBlockStyle}"
                            Text="Performance" />

                        <Border
                            Padding="12"
                            Style="{StaticResource SubtlePanelCardStyle}">
                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel
                                    x:Name="PerformanceModeButtonStackPanel"
                                    Spacing="8">
                                    <Button
                                        x:Name="PerformanceSilentButton"
                                        Click="OnPerformanceModeButtonClick"
                                        HorizontalContentAlignment="Stretch"
                                        HorizontalAlignment="Stretch"
                                        Padding="0"
                                        Style="{StaticResource SubtleButtonStyle}"
                                        Tag="silent" />
                                    <Button
                                        x:Name="PerformanceSmartButton"
                                        Click="OnPerformanceModeButtonClick"
                                        HorizontalContentAlignment="Stretch"
                                        HorizontalAlignment="Stretch"
                                        Padding="0"
                                        Style="{StaticResource SubtleButtonStyle}"
                                        Tag="smart" />
                                    <Button
                                        x:Name="PerformanceExtremeButton"
                                        Click="OnPerformanceModeButtonClick"
                                        HorizontalContentAlignment="Stretch"
                                        HorizontalAlignment="Stretch"
                                        Padding="0"
                                        Style="{StaticResource SubtleButtonStyle}"
                                        Tag="extreme" />
                                </StackPanel>

                                <Border
                                    Grid.Column="1"
                                    MinHeight="{Binding ActualHeight, ElementName=PerformanceModeButtonStackPanel, Mode=OneWay}"
                                    Padding="12"
                                    Style="{StaticResource InsetPanelCardStyle}"
                                    VerticalAlignment="Stretch">
                                    <Grid>
                                        <TextBlock
                                            x:Name="PerformanceModeDescriptionTextBlock"
                                            Style="{StaticResource BodyTextBlockStyle}"
                                            TextWrapping="WrapWholeWords"
                                            VerticalAlignment="Top" />

                                        <Canvas
                                            x:Name="PerformanceSilentCatCanvas"
                                            Width="118"
                                            Height="76"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Bottom"
                                            IsHitTestVisible="False"
                                            Margin="0,0,0,-12"
                                            Opacity="0.22"
                                            Visibility="Collapsed">
                                            <Image x:Name="PerformanceSilentCatImage" Width="118" Height="76" />
                                        </Canvas>

                                        <Canvas
                                            x:Name="PerformanceSmartCatCanvas"
                                            Width="118"
                                            Height="76"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Bottom"
                                            IsHitTestVisible="False"
                                            Margin="0,0,0,-12"
                                            Opacity="0.22"
                                            Visibility="Collapsed">
                                            <Image x:Name="PerformanceSmartCatImage" Width="118" Height="76" />
                                        </Canvas>

                                        <Canvas
                                            x:Name="PerformanceExtremeCatCanvas"
                                            Width="118"
                                            Height="76"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Bottom"
                                            IsHitTestVisible="False"
                                            Margin="0,0,0,-12"
                                            Opacity="0.22"
                                            Visibility="Collapsed">
                                            <Image x:Name="PerformanceExtremeCatImage" Width="118" Height="76" />
                                        </Canvas>

                                        <Canvas
                                            x:Name="PerformanceBatteryCatCanvas"
                                            Width="118"
                                            Height="76"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Bottom"
                                            IsHitTestVisible="False"
                                            Margin="0,0,0,-12"
                                            Opacity="0.22"
                                            Visibility="Collapsed">
                                            <Image x:Name="PerformanceBatteryCatImage" Width="118" Height="76" />
                                        </Canvas>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>

                        <Border
                            Style="{StaticResource SubtlePanelCardStyle}">
                            <StackPanel
                                x:Name="PerformanceCycleSettingsPanel"
                                Spacing="8">
                                <TextBlock
                                    x:Uid="PerformanceCycleTitleTextBlock"
                                    Style="{StaticResource CardTitleTextBlockStyle}"
                                    Text="Cycle order"
                                    TextWrapping="WrapWholeWords" />
                                <TextBlock
                                    x:Uid="PerformanceCycleDescriptionTextBlock"
                                    Style="{StaticResource CaptionTextBlockStyle}"
                                    Text="Checked modes are included when cycling. Top to bottom is the switch order. The first mode becomes the default performance mode."
                                    TextWrapping="WrapWholeWords" />

                                <ItemsControl
                                    ItemsSource="{x:Bind Controller.PerformanceCycleModeItems}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border
                                                Margin="0,1,0,1"
                                                Padding="8,4"
                                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                BorderThickness="1"
                                                CornerRadius="8">
                                                <Grid
                                                    MinHeight="28"
                                                    ColumnSpacing="8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <CheckBox
                                                        Click="OnPerformanceCycleModeIncludeClick"
                                                        IsChecked="{Binding IsIncluded, Mode=OneWay}"
                                                        IsEnabled="{Binding CanChangeInclusion, Mode=OneWay}"
                                                        Tag="{Binding Key}"
                                                        Content="{Binding Label}" />

                                                    <Button
                                                        Grid.Column="1"
                                                        Width="24"
                                                        Height="24"
                                                        Margin="6,0,0,0"
                                                        Padding="0"
                                                        Click="OnPerformanceCycleMoveUpClick"
                                                        IsEnabled="{Binding CanMoveUp, Mode=OneWay}"
                                                        Style="{StaticResource SubtleButtonStyle}"
                                                        Tag="{Binding Key}">
                                                        <FontIcon FontSize="11" FontFamily="Segoe MDL2 Assets" Glyph="&#xE70E;" />
                                                    </Button>

                                                    <Button
                                                        Grid.Column="2"
                                                        Width="24"
                                                        Height="24"
                                                        Margin="4,0,0,0"
                                                        Padding="0"
                                                        Click="OnPerformanceCycleMoveDownClick"
                                                        IsEnabled="{Binding CanMoveDown, Mode=OneWay}"
                                                        Style="{StaticResource SubtleButtonStyle}"
                                                        Tag="{Binding Key}">
                                                        <FontIcon FontSize="11" FontFamily="Segoe MDL2 Assets" Glyph="&#xE70D;" />
                                                    </Button>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <InfoBar
                            x:Uid="PerformanceBatteryInfoBar"
                            IsClosable="False"
                            IsOpen="True"
                            Severity="Informational"
                            Title="" />

                        <Border
                            Style="{StaticResource SubtlePanelCardStyle}"
                            Padding="12">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock
                                    x:Uid="SwitchToBatteryModeOnDcLabelTextBlock"
                                    x:Name="SwitchToBatteryModeOnDcLabelTextBlock"
                                    Style="{StaticResource CardTitleTextBlockStyle}"
                                    Text="Enable Battery saver automatically while on battery"
                                    TextWrapping="WrapWholeWords"
                                    VerticalAlignment="Center" />
                                <ComboBox
                                    x:Name="SwitchToBatteryModeOnDcComboBox"
                                    Grid.Column="1"
                                    MinWidth="112"
                                    SelectionChanged="OnSwitchToBatteryModeOnDcSelectionChanged"
                                    VerticalAlignment="Center">
                                    <ComboBoxItem
                                        x:Uid="SwitchToBatteryModeOnDcNeverItem"
                                        Content="Never"
                                        Tag="0" />
                                    <ComboBoxItem Content="10%" Tag="10" />
                                    <ComboBoxItem Content="20%" Tag="20" />
                                    <ComboBoxItem Content="30%" Tag="30" />
                                    <ComboBoxItem Content="40%" Tag="40" />
                                    <ComboBoxItem Content="50%" Tag="50" />
                                    <ComboBoxItem Content="60%" Tag="60" />
                                    <ComboBoxItem Content="70%" Tag="70" />
                                    <ComboBoxItem Content="80%" Tag="80" />
                                    <ComboBoxItem Content="90%" Tag="90" />
                                    <ComboBoxItem
                                        x:Uid="SwitchToBatteryModeOnDcAlwaysItem"
                                        Content="Always"
                                        Tag="-1" />
                                </ComboBox>
                            </Grid>
                        </Border>

                    </StackPanel>
                </Border>

                <Border
                    x:Name="ChargeCard"
                    Grid.Row="2"
                    Visibility="Collapsed"
                    Style="{StaticResource PanelCardStyle}">
                    <StackPanel Spacing="14">
                        <TextBlock
                            x:Uid="BatteryChargeTitleText"
                            Style="{StaticResource SectionTitleTextBlockStyle}"
                            Text="Smart charging" />

                        <InfoBar
                            x:Uid="BatteryChargeInfoBar"
                            IsClosable="False"
                            IsOpen="True"
                            Severity="Informational" />

                        <Border
                            Style="{StaticResource SubtlePanelCardStyle}"
                            Padding="12">
                            <StackPanel Spacing="8">
                                <TextBlock
                                    x:Uid="ChargeLimitLabelTextBlock"
                                    x:Name="ChargeLimitLabelTextBlock"
                                    Style="{StaticResource CardTitleTextBlockStyle}"
                                    Text="Charge limit"
                                    VerticalAlignment="Top" />

                                <Slider
                                    x:Name="ChargeLimitSlider"
                                    Width="360"
                                    HorizontalAlignment="Left"
                                    IsThumbToolTipEnabled="True"
                                    KeyDown="OnChargeLimitSliderKeyDown"
                                    KeyUp="OnChargeLimitSliderKeyUp"
                                    LostFocus="OnChargeLimitSliderLostFocus"
                                    Maximum="100"
                                    Minimum="60"
                                    PointerCaptureLost="OnChargeLimitSliderPointerCaptureLost"
                                    PointerPressed="OnChargeLimitSliderPointerPressed"
                                    PointerReleased="OnChargeLimitSliderPointerReleased"
                                    SmallChange="10"
                                    SnapsTo="Ticks"
                                    StepFrequency="10"
                                    TickFrequency="10"
                                    TickPlacement="BottomRight"
                                    SizeChanged="OnChargeLimitSliderSizeChanged"
                                    ValueChanged="OnChargeLimitSliderValueChanged" />

                                <Canvas
                                    x:Name="ChargeLimitTickLabelsCanvas"
                                    Width="360"
                                    Height="20"
                                    HorizontalAlignment="Left"
                                    IsHitTestVisible="False">
                                    <TextBlock
                                        x:Name="Charge60Label"
                                        Style="{StaticResource CaptionTextBlockStyle}"
                                        Text="60%" />
                                    <TextBlock
                                        x:Name="Charge70Label"
                                        Style="{StaticResource CaptionTextBlockStyle}"
                                        Text="70%" />
                                    <TextBlock
                                        x:Name="Charge80Label"
                                        Style="{StaticResource CaptionTextBlockStyle}"
                                        Text="80%" />
                                    <TextBlock
                                        x:Name="Charge90Label"
                                        Style="{StaticResource CaptionTextBlockStyle}"
                                        Text="90%" />
                                    <TextBlock
                                        x:Name="Charge100Label"
                                        Style="{StaticResource CaptionTextBlockStyle}"
                                        Text="100%" />
                                </Canvas>
                            </StackPanel>
                        </Border>

                        <Border
                            Style="{StaticResource SubtlePanelCardStyle}"
                            Padding="12">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock
                                    x:Uid="ChargeStartupResetLabelTextBlock"
                                    x:Name="ChargeStartupResetLabelTextBlock"
                                    Style="{StaticResource CardTitleTextBlockStyle}"
                                    Text="Apply charge limit automatically on startup"
                                    TextWrapping="WrapWholeWords"
                                    VerticalAlignment="Center" />
                                <ToggleSwitch
                                    x:Name="ChargeStartupApplyToggleSwitch"
                                    Grid.Column="1"
                                    Toggled="OnChargeStartupApplyToggled"
                                    VerticalAlignment="Center">
                                </ToggleSwitch>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>
        </Grid>
    </ScrollViewer>
</Page>
