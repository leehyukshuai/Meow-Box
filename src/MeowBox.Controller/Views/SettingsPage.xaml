<Page
    x:Class="MeowBox.Controller.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer HorizontalScrollBarVisibility="Disabled">
        <Grid Padding="{StaticResource AppPagePadding}" RowSpacing="16">
            <Grid x:Name="SettingsSectionsGrid" RowSpacing="16">
                <VisualStateManager.VisualStateGroups>
                    <VisualStateGroup>
                        <VisualState x:Name="WideLayout">
                            <VisualState.StateTriggers>
                                <AdaptiveTrigger MinWindowWidth="1040" />
                            </VisualState.StateTriggers>
                            <VisualState.Setters>
                                <Setter Target="SettingsSectionsGrid.ColumnSpacing" Value="16" />
                                <Setter Target="SettingsLeftColumn.Width" Value="*" />
                                <Setter Target="SettingsRightColumn.Width" Value="*" />
                                <Setter Target="ServiceCard.(Grid.Row)" Value="0" />
                                <Setter Target="ServiceCard.(Grid.Column)" Value="0" />
                                <Setter Target="AppearanceCard.(Grid.Row)" Value="0" />
                                <Setter Target="AppearanceCard.(Grid.Column)" Value="1" />
                                <Setter Target="ConfigsCard.(Grid.Row)" Value="1" />
                                <Setter Target="ConfigsCard.(Grid.Column)" Value="0" />
                                <Setter Target="DeviceCard.(Grid.Row)" Value="1" />
                                <Setter Target="DeviceCard.(Grid.Column)" Value="1" />
                            </VisualState.Setters>
                        </VisualState>
                    </VisualStateGroup>
                </VisualStateManager.VisualStateGroups>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="SettingsLeftColumn" Width="*" />
                    <ColumnDefinition x:Name="SettingsRightColumn" Width="0" />
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border x:Name="ServiceCard" Grid.Row="0" Grid.Column="0" Style="{StaticResource PanelCardStyle}">
                    <Grid RowSpacing="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock x:Uid="ServiceCardTitleText" Style="{StaticResource SectionTitleTextBlockStyle}" Text="Service" />

                        <Grid Grid.Row="1" ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Uid="ServiceRunningText" VerticalAlignment="Center" Style="{StaticResource CardTitleTextBlockStyle}" Text="Running" />
                            <ToggleSwitch x:Name="ServiceToggleSwitch" Grid.Column="1" Toggled="OnServiceStateChanged" />
                        </Grid>

                        <Grid Grid.Row="2" ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Uid="TrayIconText" VerticalAlignment="Center" Style="{StaticResource CardTitleTextBlockStyle}" Text="Tray icon" />
                            <ToggleSwitch x:Name="TrayIconToggleSwitch" Grid.Column="1" Toggled="OnTrayIconChanged" />
                        </Grid>
                    </Grid>
                </Border>

                <Border x:Name="AppearanceCard" Grid.Row="1" Grid.Column="0" Style="{StaticResource PanelCardStyle}">
                    <StackPanel Spacing="14">
                        <TextBlock x:Uid="AppearanceCardTitleText" Style="{StaticResource SectionTitleTextBlockStyle}" Text="Appearance" />

                        <ComboBox x:Uid="ThemeComboBox" x:Name="ThemeComboBox" Header="Theme" SelectionChanged="OnThemeSelectionChanged">
                            <ComboBoxItem x:Uid="ThemeSystemItem" x:Name="ThemeSystemItem" Content="Use system theme" Tag="System" />
                            <ComboBoxItem x:Uid="ThemeLightItem" Content="Light" Tag="Light" />
                            <ComboBoxItem x:Uid="ThemeDarkItem" Content="Dark" Tag="Dark" />
                        </ComboBox>

                        <StackPanel Spacing="4">
                            <ComboBox x:Uid="LanguageComboBox" x:Name="LanguageComboBox" Header="Language" SelectionChanged="OnLanguageSelectionChanged">
                                <ComboBoxItem x:Uid="LanguageSystemItem" x:Name="LanguageSystemItem" Content="Use system language" Tag="System" />
                                <ComboBoxItem x:Uid="LanguageEnglishItem" Content="English" Tag="English" />
                                <ComboBoxItem x:Uid="LanguageChineseItem" Content="Chinese" Tag="Chinese" />
                            </ComboBox>
                            <TextBlock x:Uid="LanguageRestartHintText" Style="{StaticResource CaptionTextBlockStyle}" Text="Language changes apply after restarting the app." TextWrapping="WrapWholeWords" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border x:Name="ConfigsCard" Grid.Row="2" Grid.Column="0" Style="{StaticResource PanelCardStyle}">
                    <Grid RowSpacing="14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock x:Uid="ConfigsCardTitleText" Style="{StaticResource SectionTitleTextBlockStyle}" Text="Details" />

                        <Border Grid.Row="1" Style="{StaticResource InsetPanelCardStyle}">
                            <Grid RowSpacing="12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock x:Uid="OsdSettingsTitleText" Style="{StaticResource CardTitleTextBlockStyle}" Text="OSD" />

                                <Grid Grid.Row="1" ColumnSpacing="16" RowSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <ComboBox x:Uid="OsdDisplayModeComboBox" x:Name="OsdDisplayModeComboBox" Header="OSD content" SelectionChanged="OnOsdSettingChanged">
                                        <ComboBoxItem x:Uid="OsdDisplayIconAndTitleItem" Content="Icon + title" Tag="IconAndText" />
                                        <ComboBoxItem x:Uid="OsdDisplayIconOnlyItem" Content="Icon only" Tag="IconOnly" />
                                        <ComboBoxItem x:Uid="OsdDisplayTitleOnlyItem" Content="Title only" Tag="TextOnly" />
                                    </ComboBox>

                                    <NumberBox x:Uid="OsdDurationNumberBox" x:Name="OsdDurationNumberBox" Grid.Column="1" Header="OSD duration (ms)" Minimum="500" Maximum="10000" SmallChange="100" SpinButtonPlacementMode="Inline" ValueChanged="OnOsdNumberValueChanged" />
                                    <NumberBox x:Uid="OsdBackgroundOpacityNumberBox" x:Name="OsdBackgroundOpacityNumberBox" Grid.Row="1" Header="Background opacity (%)" Minimum="0" Maximum="100" SmallChange="5" SpinButtonPlacementMode="Inline" ValueChanged="OnOsdNumberValueChanged" />
                                    <NumberBox x:Uid="OsdScaleNumberBox" x:Name="OsdScaleNumberBox" Grid.Row="1" Grid.Column="1" Header="OSD size (%)" Minimum="60" Maximum="200" SmallChange="10" SpinButtonPlacementMode="Inline" ValueChanged="OnOsdNumberValueChanged" />
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <Border x:Name="DeviceCard" Grid.Row="3" Grid.Column="0" Style="{StaticResource PanelCardStyle}">
                    <StackPanel Spacing="14">
                        <TextBlock x:Uid="DeviceCardTitleText" Style="{StaticResource SectionTitleTextBlockStyle}" Text="Configuration" />

                        <TextBox x:Uid="ConfigPathTextBox" x:Name="ConfigPathTextBox" Header="Config file" IsReadOnly="True" />

                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Button x:Uid="OpenConfigFolderButton" Click="OnOpenConfigFolderClick" Content="Open config folder" Style="{StaticResource AccentButtonStyle}" />
                            <Button x:Uid="RestoreDefaultsButton" Click="OnRestoreDefaultsClick" Content="Restore defaults" Style="{StaticResource DangerButtonStyle}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border x:Name="SupportCard" Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource PanelCardStyle}">
                    <StackPanel Spacing="14">
                        <TextBlock x:Uid="OpenSourceSupportCardTitleText" Style="{StaticResource SectionTitleTextBlockStyle}" Text="Open source and support" />

                        <Border Style="{StaticResource SubtlePanelCardStyle}">
                            <StackPanel Spacing="10">
                                <TextBlock x:Uid="ProjectIntroTitleText" Style="{StaticResource CardTitleTextBlockStyle}" Text="Project intro" />
                                <TextBlock Style="{StaticResource CardBodyTextBlockStyle}" TextWrapping="Wrap">
                                    <Run x:Uid="ProjectIntroBodyRun" Text="Meow Box is an open-source tool for Xiaomi Book Pro 14 2026, an open-source alternative to Xiaomi PC Manager, and is not compatible with Xiaomi PC Manager. Project link: " />
                                    <Hyperlink Click="OnOpenGitHubClick">https://github.com/leehyukshuai/Meow-Box</Hyperlink>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SubtlePanelCardStyle}">
                            <StackPanel Spacing="10">
                                <TextBlock x:Uid="DonationTitleText" Style="{StaticResource CardTitleTextBlockStyle}" Text="Support the author" />
                                <TextBlock Style="{StaticResource CardBodyTextBlockStyle}" TextWrapping="Wrap">
                                    <Run x:Uid="DonationDescriptionRun" Text="If this software helps you, you are welcome to buy the author a milk tea and support future development. Afdian link: " />
                                    <Hyperlink Click="OnOpenAfdianClick">https://ifdian.net/a/Willowbank-September</Hyperlink>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SubtlePanelCardStyle}">
                            <StackPanel Spacing="12">
                                <TextBlock x:Uid="ActivationTitleText" Style="{StaticResource CardTitleTextBlockStyle}" Text="Activate easter eggs" />
                                <TextBlock x:Name="ActivationStatusTextBlock" Style="{StaticResource CardBodyTextBlockStyle}" Text="Not activated yet. Donate on Afdian to get an activation code." TextWrapping="Wrap" />
                                <Grid ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Uid="ActivationCodeTextBox" x:Name="ActivationCodeTextBox" PlaceholderText="Enter activation code" />
                                    <Button x:Uid="ActivateEasterEggsButton" x:Name="ActivateEasterEggsButton" Grid.Column="1" VerticalAlignment="Stretch" Click="OnActivateEasterEggsClick" Content="Activate" Style="{StaticResource AccentButtonStyle}" />
                                </Grid>
                                <Grid x:Name="EasterEggVisibilityRow" ColumnSpacing="16" Visibility="Collapsed">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Spacing="3">
                                        <TextBlock x:Uid="ShowEasterEggsTitleText" Style="{StaticResource CardTitleTextBlockStyle}" Text="Show easter eggs" />
                                        <TextBlock x:Uid="ShowEasterEggsDescriptionText" Style="{StaticResource CaptionTextBlockStyle}" Text="Display playful cat decorations in the interface." TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                    <ToggleSwitch x:Name="ShowEasterEggsToggleSwitch" Grid.Column="1" Toggled="OnShowEasterEggsChanged" />
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</Page>
