<ContentDialog
    x:Class="MeowBox.Controller.Views.AppPickerDialog"
    x:Uid="AppPickerDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    PrimaryButtonText="Choose app"
    CloseButtonText="Cancel"
    DefaultButton="Primary"
    mc:Ignorable="d">

    <StackPanel Width="600" Spacing="16">
        <StackPanel Spacing="6">
            <TextBlock x:Uid="AppPickerEyebrowText" Style="{StaticResource SectionEyebrowTextBlockStyle}" Text="Application picker" />
            <TextBlock x:Uid="AppPickerTitleText" Style="{StaticResource SectionTitleTextBlockStyle}" Text="Choose what this mapping should launch" />
            <TextBlock x:Uid="AppPickerDescriptionText" Style="{StaticResource CardBodyTextBlockStyle}" Text="Search installed apps by name, then pick the one that best matches the action you want from the hardware key." TextWrapping="WrapWholeWords" />
        </StackPanel>

        <TextBox x:Uid="AppPickerSearchTextBox" x:Name="SearchTextBox" Header="Search installed apps" PlaceholderText="Type part of the app name" TextChanged="OnSearchTextChanged" />

        <InfoBar x:Uid="LoadingInfoBar" x:Name="LoadingInfoBar" IsClosable="False" IsOpen="True" Severity="Informational" Title="Installed apps" />

        <ListView
            x:Name="AppsListView"
            Height="400"
            Style="{StaticResource ListHostStyle}"
            SelectionMode="Single"
            SelectionChanged="OnSelectionChanged">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Grid Grid.RowSpan="2" Width="32" Height="32" Margin="6" VerticalAlignment="Center">
                            <Ellipse Fill="{StaticResource ListIconBackgroundBrush}" />
                            <FontIcon HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe Fluent Icons" FontSize="13" Foreground="{StaticResource ListIconForegroundBrush}" Glyph="&#xECAA;" />
                        </Grid>

                        <TextBlock Grid.Column="1" Margin="12,6,0,0" Style="{ThemeResource BaseTextBlockStyle}" Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Margin="12,0,0,6" Style="{ThemeResource BodyTextBlockStyle}" Text="{Binding AppId}" TextTrimming="CharacterEllipsis" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </StackPanel>
</ContentDialog>
