<ContentDialog
    x:Class="MeowBox.Controller.Views.ActionPickerDialog"
    x:Uid="ActionPickerDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    PrimaryButtonText="Choose action"
    CloseButtonText="Cancel"
    DefaultButton="Primary">

    <Grid Width="640" RowSpacing="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Spacing="6">
            <TextBlock x:Uid="ActionPickerTitleText" Style="{StaticResource SectionTitleTextBlockStyle}" Text="Choose action" />
            <TextBlock x:Uid="ActionPickerDescriptionText" Style="{StaticResource CardBodyTextBlockStyle}" Text="Pick the action this mapping should run." TextWrapping="WrapWholeWords" />
        </StackPanel>

        <Grid Grid.Row="1" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ComboBox x:Uid="ActionPickerCategoryComboBox" x:Name="CategoryComboBox" DisplayMemberPath="Label" Header="Category" SelectionChanged="OnFilterChanged" />
            <TextBox x:Uid="ActionPickerSearchTextBox" x:Name="SearchTextBox" Grid.Column="1" Header="Search" PlaceholderText="Type part of the action name" TextChanged="OnFilterChanged" />
        </Grid>

        <ListView
            x:Name="ActionsListView"
            Grid.Row="2"
            Height="420"
            Style="{StaticResource ListHostStyle}"
            SelectionMode="Single"
            SelectionChanged="OnSelectionChanged">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Grid Grid.RowSpan="2" Width="32" Height="32" Margin="6" VerticalAlignment="Center">
                            <Ellipse Fill="{ThemeResource AccentFillColorDefaultBrush}" />
                            <FontIcon HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe Fluent Icons" FontSize="14" Foreground="{StaticResource ListIconForegroundBrush}" Glyph="{Binding IconGlyph}" />
                        </Grid>

                        <TextBlock Grid.Column="1" Margin="12,6,0,0" Style="{ThemeResource BaseTextBlockStyle}" Text="{Binding Label}" TextTrimming="CharacterEllipsis" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Margin="12,0,0,6" Style="{ThemeResource BodyTextBlockStyle}" Text="{Binding Description}" TextTrimming="CharacterEllipsis" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</ContentDialog>
