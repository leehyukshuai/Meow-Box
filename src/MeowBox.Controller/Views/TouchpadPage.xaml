<Page
    x:Class="MeowBox.Controller.Views.TouchpadPage"
    x:Name="TouchpadPageRoot"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <DataTemplate x:Key="TouchpadActionEditorTemplate">
            <Border
                HorizontalAlignment="Stretch"
                Style="{StaticResource SubtlePanelCardStyle}">
                <StackPanel Spacing="14">
                    <StackPanel Spacing="8">
                        <TextBlock
                            Style="{StaticResource CardTitleTextBlockStyle}"
                            Text="{Binding Title}" />
                        <TextBlock
                            Style="{StaticResource CardBodyTextBlockStyle}"
                            Text="{Binding Description}"
                            TextWrapping="WrapWholeWords" />
                        <ItemsControl
                            ItemsSource="{Binding GuidanceLines}"
                            Visibility="{Binding GuidanceVisibility}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock
                                        Margin="0,0,0,2"
                                        Style="{StaticResource CaptionTextBlockStyle}"
                                        Text="{Binding}"
                                        TextWrapping="WrapWholeWords" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <StackPanel
                            Orientation="Horizontal"
                            Spacing="12"
                            Visibility="{Binding StandardActionPickerVisibility}">
                        <Button
                            Click="OnChooseTouchpadActionClick"
                            Content="Choose action"
                            Style="{StaticResource SubtleButtonStyle}" />
                        <Button
                            Click="OnClearTouchpadActionClick"
                            Content="Clear action"
                            IsEnabled="{Binding Action.HasAssignedAction}"
                            Style="{StaticResource SubtleButtonStyle}" />
                        </StackPanel>
                        <StackPanel
                            Spacing="10"
                            Visibility="{Binding SimpleEdgeSlideMappingVisibility}">
                            <RadioButton Content="关闭映射" IsChecked="{Binding IsEdgeSlideMappingOff, Mode=TwoWay}" />
                            <RadioButton Content="调节音量" IsChecked="{Binding IsEdgeSlideMappingVolume, Mode=TwoWay}" />
                            <RadioButton Content="调节亮度" IsChecked="{Binding IsEdgeSlideMappingBrightness, Mode=TwoWay}" />
                        </StackPanel>
                    </StackPanel>

                    <Border
                        Style="{StaticResource SubtlePanelCardStyle}"
                        Visibility="{Binding StandardActionPickerVisibility}">
                        <StackPanel Spacing="12">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border
                                    Width="32"
                                    Height="32"
                                    Background="{StaticResource ShellInfoSoftBrush}"
                                    CornerRadius="8">
                                    <FontIcon
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontFamily="Segoe Fluent Icons"
                                        FontSize="14"
                                        Glyph="{Binding ActionIconGlyph}" />
                                </Border>

                                <StackPanel Grid.Column="1" Spacing="4">
                                    <TextBlock
                                        Style="{StaticResource CardTitleTextBlockStyle}"
                                        Text="{Binding ActionSummary}" />
                                    <TextBlock
                                        Style="{StaticResource CardBodyTextBlockStyle}"
                                        Text="{Binding ActionDescription}"
                                        TextWrapping="WrapWholeWords" />
                                </StackPanel>
                            </Grid>

                            <StackPanel
                                Spacing="12"
                                Visibility="{Binding Action.TargetVisibility}">
                                <TextBox
                                    Header="Target"
                                    LostFocus="OnTouchpadEditorLostFocus"
                                    PlaceholderText="Installed app target or executable path"
                                    Text="{Binding Action.Target, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <StackPanel
                                    Orientation="Horizontal"
                                    Spacing="12"
                                    Visibility="{Binding Action.InstalledAppPickerVisibility}">
                                    <Button
                                        Click="OnPickInstalledAppClick"
                                        Content="Choose app"
                                        Style="{StaticResource SubtleButtonStyle}" />
                                    <Button
                                        Click="OnBrowseExecutableClick"
                                        Content="Browse file"
                                        Style="{StaticResource SubtleButtonStyle}" />
                                </StackPanel>
                                <TextBox
                                    Header="Arguments"
                                    LostFocus="OnTouchpadEditorLostFocus"
                                    PlaceholderText="Optional launch arguments"
                                    Text="{Binding Action.Arguments, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Visibility="{Binding Action.ArgumentsVisibility}" />
                            </StackPanel>

                            <StackPanel
                                Spacing="12"
                                Visibility="{Binding Action.KeyChordEditorVisibility}">
                                <Grid RowSpacing="12">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <StackPanel Spacing="8">
                                        <TextBlock
                                            Style="{StaticResource CaptionTextBlockStyle}"
                                            Text="{Binding Action.KeyChordEditor.ModifiersHeader}" />
                                        <Grid ColumnSpacing="12" RowSpacing="4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <CheckBox
                                                Content="{Binding Action.KeyChordEditor.ControlModifier.Label}"
                                                IsChecked="{Binding Action.KeyChordEditor.ControlModifier.IsSelected, Mode=TwoWay}" />
                                            <CheckBox
                                                Grid.Column="1"
                                                Content="{Binding Action.KeyChordEditor.ShiftModifier.Label}"
                                                IsChecked="{Binding Action.KeyChordEditor.ShiftModifier.IsSelected, Mode=TwoWay}" />
                                            <CheckBox
                                                Grid.Row="1"
                                                Content="{Binding Action.KeyChordEditor.AltModifier.Label}"
                                                IsChecked="{Binding Action.KeyChordEditor.AltModifier.IsSelected, Mode=TwoWay}" />
                                            <CheckBox
                                                Grid.Row="1"
                                                Grid.Column="1"
                                                Content="{Binding Action.KeyChordEditor.WindowsModifier.Label}"
                                                IsChecked="{Binding Action.KeyChordEditor.WindowsModifier.IsSelected, Mode=TwoWay}" />
                                        </Grid>
                                    </StackPanel>

                                    <Grid Grid.Row="1" ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <ComboBox
                                            DisplayMemberPath="Label"
                                            Header="Primary key group"
                                            ItemsSource="{Binding Action.KeyChordEditor.Groups}"
                                            SelectedItem="{Binding Action.KeyChordEditor.SelectedGroup, Mode=TwoWay}" />
                                        <ComboBox
                                            Grid.Column="1"
                                            DisplayMemberPath="Label"
                                            Header="Primary key"
                                            ItemsSource="{Binding Action.KeyChordEditor.FilteredPrimaryKeys}"
                                            SelectedItem="{Binding Action.KeyChordEditor.SelectedPrimaryKey, Mode=TwoWay}" />
                                    </Grid>

                                    <StackPanel Grid.Row="2" Spacing="4">
                                        <TextBlock
                                            Style="{StaticResource CaptionTextBlockStyle}"
                                            Text="{Binding Action.KeyChordEditor.PreviewHeader}" />
                                        <TextBlock
                                            Style="{StaticResource CardBodyTextBlockStyle}"
                                            Text="{Binding Action.KeyChordDisplayText}"
                                            TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </DataTemplate>
    </Page.Resources>

    <ScrollViewer HorizontalScrollBarVisibility="Disabled">
        <Grid Padding="{StaticResource AppPagePadding}" RowSpacing="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border
                Grid.Row="0"
                Style="{StaticResource PanelCardStyle}">
                <Grid
                    x:Name="TouchpadVisualizerLayoutGrid"
                    ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border
                        Style="{StaticResource InsetPanelCardStyle}">
                        <Grid
                            x:Name="TouchpadPreviewHost"
                            Width="460"
                            Height="298"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top">
                            <Canvas
                                x:Name="TouchpadCanvas"
                                SizeChanged="OnTouchpadCanvasSizeChanged" />

                            <StackPanel
                                x:Name="TouchpadCanvasEmptyStatePanel"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Spacing="8">
                                <FontIcon
                                    FontFamily="Segoe Fluent Icons"
                                    Style="{StaticResource EmptyStateIconStyle}"
                                    Glyph="&#xE7F4;" />
                                <TextBlock
                                    x:Uid="TouchpadVisualizerEmptyTitleText"
                                    Style="{StaticResource EmptyStateTitleTextBlockStyle}"
                                    Text="Waiting for touchpad input" />
                                <TextBlock
                                    x:Uid="TouchpadVisualizerEmptyBodyText"
                                    Style="{StaticResource EmptyStateBodyTextBlockStyle}"
                                    Text="Start the service and touch the pad to see live contact pressure."
                                    TextWrapping="WrapWholeWords" />
                            </StackPanel>

                            <TextBlock
                                x:Uid="TouchpadPressureTextBlock"
                                x:Name="TouchpadPressureTextBlock"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Bottom"
                                Margin="0,0,0,8"
                                Style="{StaticResource CardBodyTextBlockStyle}"
                                IsHitTestVisible="False"
                                Text="Pressure: 0" />
                        </Grid>
                    </Border>

                    <Border
                        x:Name="TouchpadHardwareControlPanel"
                        Grid.Column="1"
                        Style="{StaticResource InsetPanelCardStyle}">
                        <StackPanel Spacing="14">
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="112" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                            <TextBlock
                                    x:Uid="TouchpadPressSensitivityLabelText"
                                    VerticalAlignment="Center"
                                    Style="{StaticResource CardBodyTextBlockStyle}"
                                    Text="Press sensitivity" />

                                <ComboBox
                                    x:Name="TouchpadPressSensitivityComboBox"
                                    Grid.Column="1"
                                    HorizontalAlignment="Left"
                                    Width="108"
                                    SelectionChanged="OnTouchpadPressSensitivitySelectionChanged">
                                    <ComboBoxItem x:Uid="TouchpadPressSensitivityLowItem" Content="Low" Tag="1" />
                                    <ComboBoxItem x:Uid="TouchpadPressSensitivityMediumItem" Content="Medium" Tag="2" />
                                    <ComboBoxItem x:Uid="TouchpadPressSensitivityHighItem" Content="High" Tag="3" />
                                </ComboBox>
                            </Grid>

                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="112" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock
                                    x:Uid="TouchpadFeedbackLabelText"
                                    VerticalAlignment="Center"
                                    Style="{StaticResource CardBodyTextBlockStyle}"
                                    Text="Vibration strength" />

                                <ComboBox
                                    x:Name="TouchpadFeedbackComboBox"
                                    Grid.Column="1"
                                    HorizontalAlignment="Left"
                                    Width="108"
                                    SelectionChanged="OnTouchpadFeedbackSelectionChanged">
                                    <ComboBoxItem x:Uid="TouchpadFeedbackWeakItem" Content="Weak" Tag="1" />
                                    <ComboBoxItem x:Uid="TouchpadFeedbackMediumItem" Content="Medium" Tag="2" />
                                    <ComboBoxItem x:Uid="TouchpadFeedbackStrongItem" Content="Strong" Tag="3" />
                                </ComboBox>
                            </Grid>

                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="112" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock
                                    x:Uid="TouchpadDeepPressFeedbackLabelText"
                                    VerticalAlignment="Center"
                                    Style="{StaticResource CardBodyTextBlockStyle}"
                                    Text="Deep press haptics" />

                                <ComboBox
                                    x:Name="TouchpadDeepPressFeedbackComboBox"
                                    Grid.Column="1"
                                    Width="108"
                                    HorizontalAlignment="Left"
                                    SelectionChanged="OnTouchpadDeepPressFeedbackSelectionChanged">
                                    <ComboBoxItem x:Uid="TouchpadDeepPressFeedbackOffItem" Content="Off" Tag="false" />
                                    <ComboBoxItem x:Uid="TouchpadDeepPressFeedbackOnItem" Content="On" Tag="true" />
                                </ComboBox>
                            </Grid>

                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="112" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock
                                    x:Uid="TouchpadLongPressLabelText"
                                    VerticalAlignment="Center"
                                    Style="{StaticResource CardBodyTextBlockStyle}"
                                    Text="Long press duration" />

                                <ComboBox
                                    x:Name="TouchpadLongPressComboBox"
                                    Grid.Column="1"
                                    Width="108"
                                    HorizontalAlignment="Left"
                                    SelectionChanged="OnTouchpadLongPressSelectionChanged">
                                    <ComboBoxItem Content="500 ms" Tag="500" />
                                    <ComboBoxItem Content="600 ms" Tag="600" />
                                    <ComboBoxItem Content="700 ms" Tag="700" />
                                    <ComboBoxItem Content="800 ms" Tag="800" />
                                    <ComboBoxItem Content="900 ms" Tag="900" />
                                    <ComboBoxItem Content="1000 ms" Tag="1000" />
                                </ComboBox>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Grid
                Grid.Row="1"
                ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="320" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border
                    x:Name="TouchpadActionListCard"
                    Grid.Column="0"
                    Style="{StaticResource PanelCardStyle}">
                    <ListView
                        Style="{StaticResource ListHostStyle}"
                        ItemContainerStyle="{StaticResource ListHostItemStyle}"
                        ItemsSource="{Binding Touchpad.AllActionEditors}"
                        SelectedItem="{Binding Touchpad.SelectedActionEditor, Mode=TwoWay}"
                        SelectionMode="Single">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Border Width="28" Height="28" Background="{StaticResource ShellInfoSoftBrush}" CornerRadius="6">
                                        <FontIcon HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe Fluent Icons" FontSize="12" Glyph="{Binding ActionIconGlyph}" />
                                    </Border>

                                    <StackPanel Grid.Column="1" Spacing="2">
                                        <TextBlock Style="{StaticResource CardTitleTextBlockStyle}" Text="{Binding Title}" />
                                        <TextBlock Style="{StaticResource CaptionTextBlockStyle}" Text="{Binding ActionSummary}" TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Border>

                <Border
                    Grid.Column="1"
                    Height="{Binding ActualHeight, ElementName=TouchpadActionListCard}"
                    VerticalAlignment="Top"
                    Style="{StaticResource PanelCardStyle}">
                    <ScrollViewer
                        HorizontalScrollBarVisibility="Disabled"
                        VerticalScrollBarVisibility="Auto">
                        <ContentControl
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Stretch"
                            Content="{Binding Touchpad.SelectedActionEditor}"
                            ContentTemplate="{StaticResource TouchpadActionEditorTemplate}" />
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</Page>
