<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Light">
            <Color x:Key="AppBackgroundColor">#FFF7F2E8</Color>
            <Color x:Key="AppPaneBackgroundColor">#FFFAF6EE</Color>
            <Color x:Key="AppCardBackgroundColor">#FFFFFCF7</Color>
            <Color x:Key="AppSubtleBackgroundColor">#FFF1ECE2</Color>
            <Color x:Key="AppSubtleBackgroundPointerOverColor">#FFEDE5D8</Color>
            <Color x:Key="AppSubtleBackgroundPressedColor">#FFE4DACB</Color>
            <Color x:Key="AppStrokeColor">#FFE1D8CA</Color>
            <Color x:Key="AppStrokePointerOverColor">#FFD1C5B5</Color>
            <Color x:Key="AppStrokePressedColor">#FFC3B4A2</Color>
            <Color x:Key="AppDividerColor">#FFE8DFD3</Color>
            <Color x:Key="AppTextPrimaryColor">#FF22262D</Color>
            <Color x:Key="AppTextSecondaryColor">#FF606873</Color>
            <Color x:Key="AppTextDisabledColor">#8A606873</Color>
            <Color x:Key="AppButtonBackgroundColor">#FFFFFBF4</Color>
            <Color x:Key="AppButtonBackgroundPointerOverColor">#FFF0E8DB</Color>
            <Color x:Key="AppButtonBackgroundPressedColor">#FFE6DDCF</Color>
            <Color x:Key="AppButtonBorderColor">#FFE1D8CA</Color>
            <Color x:Key="AppButtonBorderPointerOverColor">#FFD1C5B5</Color>
            <Color x:Key="AppButtonBorderPressedColor">#FFC3B4A2</Color>
            <Color x:Key="AppButtonForegroundColor">#FF22262D</Color>
            <Color x:Key="DangerButtonBackgroundColor">#FFF8F2F2</Color>
            <Color x:Key="DangerButtonBorderColor">#FFE6C9C9</Color>
            <Color x:Key="DangerButtonForegroundColor">#FF8B3A3A</Color>
            <Color x:Key="ListIconForegroundColor">#FFFFFFFF</Color>
        </ResourceDictionary>
        <ResourceDictionary x:Key="Dark">
            <Color x:Key="AppBackgroundColor">#FF111318</Color>
            <Color x:Key="AppPaneBackgroundColor">#FF171A20</Color>
            <Color x:Key="AppCardBackgroundColor">#FF1B1F26</Color>
            <Color x:Key="AppSubtleBackgroundColor">#FF20252D</Color>
            <Color x:Key="AppSubtleBackgroundPointerOverColor">#FF2A303A</Color>
            <Color x:Key="AppSubtleBackgroundPressedColor">#FF242A33</Color>
            <Color x:Key="AppStrokeColor">#FF323A46</Color>
            <Color x:Key="AppStrokePointerOverColor">#FF465160</Color>
            <Color x:Key="AppStrokePressedColor">#FF3C4653</Color>
            <Color x:Key="AppDividerColor">#FF2B313B</Color>
            <Color x:Key="AppTextPrimaryColor">#FFF3F6FA</Color>
            <Color x:Key="AppTextSecondaryColor">#FFC3CAD5</Color>
            <Color x:Key="AppTextDisabledColor">#66C3CAD5</Color>
            <Color x:Key="AppButtonBackgroundColor">#FF20252D</Color>
            <Color x:Key="AppButtonBackgroundPointerOverColor">#1AFFFFFF</Color>
            <Color x:Key="AppButtonBackgroundPressedColor">#12FFFFFF</Color>
            <Color x:Key="AppButtonBorderColor">#FF323A46</Color>
            <Color x:Key="AppButtonBorderPointerOverColor">#33FFFFFF</Color>
            <Color x:Key="AppButtonBorderPressedColor">#29FFFFFF</Color>
            <Color x:Key="AppButtonForegroundColor">#FFF3F6FA</Color>
            <Color x:Key="DangerButtonBackgroundColor">#14FFB3B3</Color>
            <Color x:Key="DangerButtonBorderColor">#33FFB3B3</Color>
            <Color x:Key="DangerButtonForegroundColor">#FFFFC1C1</Color>
            <Color x:Key="ListIconForegroundColor">#FFFFFFFF</Color>
        </ResourceDictionary>
        <ResourceDictionary x:Key="Default">
            <Color x:Key="AppBackgroundColor">#FF111318</Color>
            <Color x:Key="AppPaneBackgroundColor">#FF171A20</Color>
            <Color x:Key="AppCardBackgroundColor">#FF1B1F26</Color>
            <Color x:Key="AppSubtleBackgroundColor">#FF20252D</Color>
            <Color x:Key="AppSubtleBackgroundPointerOverColor">#FF2A303A</Color>
            <Color x:Key="AppSubtleBackgroundPressedColor">#FF242A33</Color>
            <Color x:Key="AppStrokeColor">#FF323A46</Color>
            <Color x:Key="AppStrokePointerOverColor">#FF465160</Color>
            <Color x:Key="AppStrokePressedColor">#FF3C4653</Color>
            <Color x:Key="AppDividerColor">#FF2B313B</Color>
            <Color x:Key="AppTextPrimaryColor">#FFF3F6FA</Color>
            <Color x:Key="AppTextSecondaryColor">#FFC3CAD5</Color>
            <Color x:Key="AppTextDisabledColor">#66C3CAD5</Color>
            <Color x:Key="AppButtonBackgroundColor">#FF20252D</Color>
            <Color x:Key="AppButtonBackgroundPointerOverColor">#1AFFFFFF</Color>
            <Color x:Key="AppButtonBackgroundPressedColor">#12FFFFFF</Color>
            <Color x:Key="AppButtonBorderColor">#FF323A46</Color>
            <Color x:Key="AppButtonBorderPointerOverColor">#33FFFFFF</Color>
            <Color x:Key="AppButtonBorderPressedColor">#29FFFFFF</Color>
            <Color x:Key="AppButtonForegroundColor">#FFF3F6FA</Color>
            <Color x:Key="DangerButtonBackgroundColor">#14FFB3B3</Color>
            <Color x:Key="DangerButtonBorderColor">#33FFB3B3</Color>
            <Color x:Key="DangerButtonForegroundColor">#FFFFC1C1</Color>
            <Color x:Key="ListIconForegroundColor">#FFFFFFFF</Color>
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>

    <SolidColorBrush x:Key="ApplicationPageBackgroundThemeBrush" Color="{ThemeResource AppBackgroundColor}" />
    <SolidColorBrush x:Key="LayerFillColorDefaultBrush" Color="{ThemeResource AppBackgroundColor}" />
    <SolidColorBrush x:Key="LayerFillColorAltBrush" Color="{ThemeResource AppSubtleBackgroundColor}" />
    <SolidColorBrush x:Key="CardBackgroundFillColorDefaultBrush" Color="{ThemeResource AppCardBackgroundColor}" />
    <SolidColorBrush x:Key="CardStrokeColorDefaultBrush" Color="{ThemeResource AppStrokeColor}" />
    <SolidColorBrush x:Key="DividerStrokeColorDefaultBrush" Color="{ThemeResource AppDividerColor}" />
    <SolidColorBrush x:Key="TextFillColorPrimaryBrush" Color="{ThemeResource AppTextPrimaryColor}" />
    <SolidColorBrush x:Key="TextFillColorSecondaryBrush" Color="{ThemeResource AppTextSecondaryColor}" />
    <SolidColorBrush x:Key="TextFillColorDisabledBrush" Color="{ThemeResource AppTextDisabledColor}" />
    <SolidColorBrush x:Key="SubtleFillColorSecondaryBrush" Color="{ThemeResource AppSubtleBackgroundPointerOverColor}" />
    <SolidColorBrush x:Key="SubtleFillColorTertiaryBrush" Color="{ThemeResource AppSubtleBackgroundPressedColor}" />
    <SolidColorBrush x:Key="ControlFillColorDefaultBrush" Color="{ThemeResource AppButtonBackgroundColor}" />
    <SolidColorBrush x:Key="ControlFillColorSecondaryBrush" Color="{ThemeResource AppButtonBackgroundPointerOverColor}" />
    <SolidColorBrush x:Key="ControlFillColorTertiaryBrush" Color="{ThemeResource AppButtonBackgroundPressedColor}" />
    <SolidColorBrush x:Key="ControlFillColorInputActiveBrush" Color="{ThemeResource AppCardBackgroundColor}" />
    <SolidColorBrush x:Key="ControlFillColorDisabledBrush" Color="{ThemeResource AppSubtleBackgroundPressedColor}" />
    <SolidColorBrush x:Key="ControlStrokeColorDefaultBrush" Color="{ThemeResource AppStrokeColor}" />
    <SolidColorBrush x:Key="ControlElevationBorderBrush" Color="{ThemeResource AppStrokeColor}" />
    <SolidColorBrush x:Key="TextControlBackground" Color="{ThemeResource AppButtonBackgroundColor}" />
    <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="{ThemeResource AppButtonBackgroundPointerOverColor}" />
    <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="{ThemeResource AppCardBackgroundColor}" />
    <SolidColorBrush x:Key="TextControlBackgroundDisabled" Color="{ThemeResource AppSubtleBackgroundPressedColor}" />
    <SolidColorBrush x:Key="ComboBoxBackground" Color="{ThemeResource AppButtonBackgroundColor}" />
    <SolidColorBrush x:Key="ComboBoxBackgroundPointerOver" Color="{ThemeResource AppButtonBackgroundPointerOverColor}" />
    <SolidColorBrush x:Key="ComboBoxBackgroundPressed" Color="{ThemeResource AppButtonBackgroundPressedColor}" />
    <SolidColorBrush x:Key="ComboBoxBackgroundFocused" Color="{ThemeResource AppButtonBackgroundColor}" />
    <SolidColorBrush x:Key="ComboBoxBackgroundUnfocused" Color="{ThemeResource AppButtonBackgroundColor}" />
    <SolidColorBrush x:Key="ComboBoxBackgroundDisabled" Color="{ThemeResource AppSubtleBackgroundPressedColor}" />
    <SolidColorBrush x:Key="ComboBoxBorderBrush" Color="{ThemeResource AppStrokeColor}" />
    <SolidColorBrush x:Key="ComboBoxBorderBrushPointerOver" Color="{ThemeResource AppStrokePointerOverColor}" />
    <SolidColorBrush x:Key="ComboBoxBorderBrushPressed" Color="{ThemeResource AppStrokePressedColor}" />
    <SolidColorBrush x:Key="ComboBoxBorderBrushDisabled" Color="{ThemeResource AppStrokeColor}" />
    <SolidColorBrush x:Key="ComboBoxForeground" Color="{ThemeResource AppTextPrimaryColor}" />
    <SolidColorBrush x:Key="ComboBoxForegroundPointerOver" Color="{ThemeResource AppTextPrimaryColor}" />
    <SolidColorBrush x:Key="ComboBoxForegroundPressed" Color="{ThemeResource AppTextPrimaryColor}" />
    <SolidColorBrush x:Key="ComboBoxForegroundFocused" Color="{ThemeResource AppTextPrimaryColor}" />
    <SolidColorBrush x:Key="ComboBoxForegroundFocusedPressed" Color="{ThemeResource AppTextPrimaryColor}" />
    <StaticResource x:Key="ComboBoxForegroundDisabled" ResourceKey="TextFillColorDisabledBrush" />
    <SolidColorBrush x:Key="ContentDialogBackground" Color="{ThemeResource AppCardBackgroundColor}" />
    <SolidColorBrush x:Key="ContentDialogBackgroundThemeBrush" Color="{ThemeResource AppCardBackgroundColor}" />
    <SolidColorBrush x:Key="ContentDialogTopOverlay" Color="{ThemeResource AppSubtleBackgroundColor}" />
    <SolidColorBrush x:Key="NavigationViewContentBackground" Color="{ThemeResource AppBackgroundColor}" />
    <SolidColorBrush x:Key="NavigationViewDefaultPaneBackground" Color="{ThemeResource AppPaneBackgroundColor}" />
    <SolidColorBrush x:Key="NavigationViewExpandedPaneBackground" Color="{ThemeResource AppPaneBackgroundColor}" />
    <SolidColorBrush x:Key="NavigationViewItemBackgroundPointerOver" Color="{ThemeResource AppSubtleBackgroundPointerOverColor}" />
    <SolidColorBrush x:Key="NavigationViewItemBackgroundPressed" Color="{ThemeResource AppSubtleBackgroundPressedColor}" />
    <SolidColorBrush x:Key="NavigationViewItemBackgroundSelected" Color="{ThemeResource AppSubtleBackgroundPointerOverColor}" />
    <SolidColorBrush x:Key="NavigationViewItemBackgroundSelectedPointerOver" Color="{ThemeResource AppSubtleBackgroundPressedColor}" />
    <SolidColorBrush x:Key="NavigationViewButtonBackgroundPointerOver" Color="{ThemeResource AppSubtleBackgroundPointerOverColor}" />
    <SolidColorBrush x:Key="NavigationViewButtonBackgroundPressed" Color="{ThemeResource AppSubtleBackgroundPressedColor}" />
    <SolidColorBrush x:Key="NavigationViewButtonForegroundPointerOver" Color="{ThemeResource AppTextPrimaryColor}" />

    <SolidColorBrush x:Key="ShellAccentSoftBrush" Color="#1F4CC473" />
    <SolidColorBrush x:Key="ShellInfoSoftBrush" Color="#1F4A90E2" />
    <SolidColorBrush x:Key="ListIconBackgroundBrush" Color="#FF4D8F73" />
    <SolidColorBrush x:Key="ListIconForegroundBrush" Color="{ThemeResource ListIconForegroundColor}" />
    <SolidColorBrush x:Key="AppPickerSelectedBackgroundBrush" Color="{ThemeResource SystemAccentColor}" Opacity="0.17" />
    <SolidColorBrush x:Key="AppPickerSelectedBorderBrush" Color="{ThemeResource SystemAccentColor}" Opacity="0.48" />
    <SolidColorBrush x:Key="AppPickerSelectedBackgroundPointerOverBrush" Color="{ThemeResource SystemAccentColor}" Opacity="0.22" />
    <SolidColorBrush x:Key="AppPickerSelectedBorderPointerOverBrush" Color="{ThemeResource SystemAccentColor}" Opacity="0.62" />
    <SolidColorBrush x:Key="ActionPickerSelectedBackgroundBrush" Color="{ThemeResource SystemAccentColor}" Opacity="0.09" />
    <SolidColorBrush x:Key="ActionPickerSelectedBorderBrush" Color="{ThemeResource SystemAccentColor}" Opacity="0.34" />
    <SolidColorBrush x:Key="ActionPickerSelectedBackgroundPointerOverBrush" Color="{ThemeResource SystemAccentColor}" Opacity="0.12" />
    <SolidColorBrush x:Key="ActionPickerSelectedBorderPointerOverBrush" Color="{ThemeResource SystemAccentColor}" Opacity="0.42" />
    <SolidColorBrush x:Key="ActionPickerPressedOverlayBrush" Color="{ThemeResource SystemAccentColor}" Opacity="0.12" />

    <SolidColorBrush x:Key="ButtonBackground" Color="{ThemeResource AppButtonBackgroundColor}" />
    <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="{ThemeResource AppButtonBackgroundPointerOverColor}" />
    <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="{ThemeResource AppButtonBackgroundPressedColor}" />
    <StaticResource x:Key="ButtonBackgroundDisabled" ResourceKey="ControlFillColorDisabledBrush" />
    <SolidColorBrush x:Key="ButtonBorderBrush" Color="{ThemeResource AppButtonBorderColor}" />
    <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="{ThemeResource AppButtonBorderPointerOverColor}" />
    <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="{ThemeResource AppButtonBorderPressedColor}" />
    <StaticResource x:Key="ButtonBorderBrushDisabled" ResourceKey="ControlStrokeColorDefaultBrush" />
    <SolidColorBrush x:Key="ButtonForeground" Color="{ThemeResource AppButtonForegroundColor}" />
    <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="{ThemeResource AppButtonForegroundColor}" />
    <SolidColorBrush x:Key="ButtonForegroundPressed" Color="{ThemeResource AppButtonForegroundColor}" />
    <StaticResource x:Key="ButtonForegroundDisabled" ResourceKey="TextFillColorDisabledBrush" />

    <StaticResource x:Key="GridViewItemBackgroundPointerOver" ResourceKey="SubtleFillColorSecondaryBrush" />
    <StaticResource x:Key="GridViewItemBackgroundPressed" ResourceKey="SubtleFillColorTertiaryBrush" />
    <StaticResource x:Key="GridViewItemBackgroundSelected" ResourceKey="SubtleFillColorSecondaryBrush" />
    <StaticResource x:Key="GridViewItemBackgroundSelectedPointerOver" ResourceKey="SubtleFillColorTertiaryBrush" />
    <StaticResource x:Key="GridViewItemBackgroundSelectedPressed" ResourceKey="SubtleFillColorSecondaryBrush" />
    <Thickness x:Key="GridViewItemSelectedBorderThickness">1</Thickness>
    <StaticResource x:Key="GridViewItemSelectedBorderBrush" ResourceKey="AccentFillColorDefaultBrush" />
    <StaticResource x:Key="GridViewItemSelectedPointerOverBorderBrush" ResourceKey="AccentFillColorSecondaryBrush" />
    <StaticResource x:Key="GridViewItemSelectedPressedBorderBrush" ResourceKey="AccentFillColorTertiaryBrush" />

    <CornerRadius x:Key="CardCornerRadius">12</CornerRadius>
    <CornerRadius x:Key="SmallCardCornerRadius">8</CornerRadius>

    <Thickness x:Key="AppPagePadding">20,16,20,20</Thickness>

    <Style x:Key="TitleBarTitleTextBlockStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}" />
    </Style>

    <Style x:Key="TitleBarSubtitleTextBlockStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
    </Style>

    <Style x:Key="CaptionTextBlockStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
    </Style>

    <Style x:Key="PageTitleTextBlockStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="24" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}" />
    </Style>

    <Style x:Key="SectionTitleTextBlockStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}" />
    </Style>

    <Style x:Key="SectionEyebrowTextBlockStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="CharacterSpacing" Value="20" />
        <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
    </Style>

    <Style x:Key="CardTitleTextBlockStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}" />
    </Style>

    <Style x:Key="CardBodyTextBlockStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
    </Style>

    <Style x:Key="EmptyStatePanelStyle" TargetType="StackPanel">
        <Setter Property="MaxWidth" Value="300" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Spacing" Value="10" />
    </Style>

    <Style x:Key="EmptyStateIconStyle" TargetType="FontIcon">
        <Setter Property="FontSize" Value="28" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
        <Setter Property="Opacity" Value="0.9" />
    </Style>

    <Style x:Key="EmptyStateTitleTextBlockStyle" TargetType="TextBlock">
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="TextAlignment" Value="Center" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}" />
    </Style>

    <Style x:Key="EmptyStateBodyTextBlockStyle" TargetType="TextBlock">
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="TextAlignment" Value="Center" />
        <Setter Property="TextWrapping" Value="WrapWholeWords" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="MaxWidth" Value="280" />
        <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
    </Style>

    <Style x:Key="BadgeBorderStyle" TargetType="Border">
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="CornerRadius" Value="{StaticResource SmallCardCornerRadius}" />
        <Setter Property="Background" Value="{ThemeResource LayerFillColorAltBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource DividerStrokeColorDefaultBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style x:Key="PanelCardStyle" TargetType="Border">
        <Setter Property="Padding" Value="18" />
        <Setter Property="CornerRadius" Value="{StaticResource CardCornerRadius}" />
        <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style x:Key="SubtlePanelCardStyle" TargetType="Border" BasedOn="{StaticResource PanelCardStyle}">
        <Setter Property="Background" Value="{ThemeResource LayerFillColorAltBrush}" />
    </Style>

    <Style x:Key="InsetPanelCardStyle" TargetType="Border" BasedOn="{StaticResource SubtlePanelCardStyle}">
        <Setter Property="Padding" Value="14" />
    </Style>

    <Style x:Key="ListHostStyle" TargetType="ListView">
        <Setter Property="Padding" Value="0" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <Style x:Key="GridHostStyle" TargetType="GridView">
        <Setter Property="Padding" Value="0" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <Style x:Key="AccentTextButtonStyle" TargetType="Button">
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="CornerRadius" Value="{StaticResource SmallCardCornerRadius}" />
        <Setter Property="UseSystemFocusVisuals" Value="False" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style x:Key="AccentButtonStyle" TargetType="Button" BasedOn="{StaticResource AccentTextButtonStyle}">
        <Setter Property="Background" Value="{ThemeResource ButtonBackground}" />
        <Setter Property="BorderBrush" Value="{ThemeResource ButtonBorderBrush}" />
        <Setter Property="Foreground" Value="{ThemeResource ButtonForeground}" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="SubtleButtonStyle" TargetType="Button" BasedOn="{StaticResource AccentTextButtonStyle}">
        <Setter Property="Background" Value="{ThemeResource ButtonBackground}" />
        <Setter Property="BorderBrush" Value="{ThemeResource ButtonBorderBrush}" />
        <Setter Property="Foreground" Value="{ThemeResource ButtonForeground}" />
    </Style>

    <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource AccentTextButtonStyle}">
        <Setter Property="Background" Value="{ThemeResource DangerButtonBackgroundColor}" />
        <Setter Property="BorderBrush" Value="{ThemeResource DangerButtonBorderColor}" />
        <Setter Property="Foreground" Value="{ThemeResource DangerButtonForegroundColor}" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="ListHostItemStyle" TargetType="ListViewItem">
        <Setter Property="UseSystemFocusVisuals" Value="False" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Stretch" />
        <Setter Property="Padding" Value="12" />
        <Setter Property="Margin" Value="0,0,0,8" />
        <Setter Property="CornerRadius" Value="{StaticResource SmallCardCornerRadius}" />
        <Setter Property="Background" Value="{ThemeResource LayerFillColorAltBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style x:Key="GridHostItemStyle" TargetType="GridViewItem">
        <Setter Property="UseSystemFocusVisuals" Value="False" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Stretch" />
        <Setter Property="Width" Value="220" />
        <Setter Property="Padding" Value="14" />
        <Setter Property="Margin" Value="0,0,12,12" />
        <Setter Property="CornerRadius" Value="{StaticResource SmallCardCornerRadius}" />
        <Setter Property="Background" Value="{ThemeResource LayerFillColorAltBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style x:Key="ActionPickerListItemStyle" TargetType="ListViewItem" BasedOn="{StaticResource ListHostItemStyle}">
        <Setter Property="Padding" Value="14" />
        <Setter Property="Margin" Value="0,0,0,10" />
        <Setter Property="MinHeight" Value="76" />
    </Style>

    <Style x:Key="AppPickerListItemStyle" TargetType="ListViewItem" BasedOn="{StaticResource ListHostItemStyle}">
        <Setter Property="Padding" Value="14,12" />
        <Setter Property="Margin" Value="0,0,0,10" />
        <Setter Property="MinHeight" Value="72" />
    </Style>
</ResourceDictionary>
